@{
    ViewData["Title"] = "الرئيسية - أوستاوي";
    @* Layout = "~/Views/Shared/_Layout.cshtml"; *@
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Manrope', sans-serif; background-color: #f8f9ff; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.4); }
        .bg-dashed { background-image: radial-gradient(circle, #cbd5e1 1px, transparent 1px); background-size: 12px 12px; }
    </style>
}

<div class="bg-[#f8f9ff] text-[#0b1c30] antialiased" dir="rtl">

    <section class="relative min-h-[85vh] flex items-center overflow-hidden bg-[#031636] text-white rounded-b-[3rem]">
        <div class="absolute inset-0 z-0">
            <div class="w-full h-full bg-cover bg-center opacity-25" style="background-image: url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=1200')"></div>
            <div class="absolute inset-0 bg-gradient-to-tr from-[#031636] via-[#031636]/90 to-transparent"></div>
        </div>
        <div class="container mx-auto px-6 relative z-10 py-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-7 space-y-8 text-right">
                    <div class="inline-flex items-center gap-3 px-4 py-2 bg-[#fd7613]/20 text-[#ffdbca] rounded-full text-sm font-bold border border-[#fd7613]/30">
                        <span class="flex h-2 w-2 relative">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#fd7613] opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#fd7613]"></span>
                        </span>
                        أكبر تجمع للفنيين المعتمدين في مصر
                    </div>
                    <h1 class="text-4xl md:text-6xl font-black leading-[1.2]">كل صنايعية منطقتك <br><span class="text-[#ffb68f] italic">في مكان واحد</span></h1>
                    <p class="text-slate-300 text-lg md:text-xl max-w-xl leading-relaxed">سواء كنت عميل بتدور على أسطى شاطر يحل مشكلتك بسرعة، أو فني محترف وعايز تزود دخلك وتلاقي شغل يدعمك.. أوستاوي هو اختيارك الذكي والمضمون.</p>
                    <div class="flex flex-wrap gap-4 pt-2">
                        <a href="/Account/Register?role=client" class="px-8 py-4 bg-[#fd7613] text-white rounded-xl font-bold shadow-lg hover:bg-[#9c4400] transition-all transform hover:-translate-y-0.5">طلب صنايعي (أنا عميل)</a>
                        <a href="/Account/Register?role=worker" class="px-8 py-4 bg-transparent text-white border-2 border-white rounded-xl font-bold hover:bg-white hover:text-[#031636] transition-all transform hover:-translate-y-0.5">انضم كفني (أنا صنايعي)</a>
                    </div>
                </div>
                <div class="lg:col-span-5 hidden lg:block">
                    <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=500&q=80" alt="Ostawy" class="rounded-3xl shadow-2xl border border-white/10 max-h-[420px] w-full object-cover">
                </div>
            </div>
        </div>
    </section>

    <div class="container mx-auto px-6 -mt-12 relative z-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
            <div class="bg-white rounded-2xl p-6 shadow-xl border-t-4 border-[#fd7613]">
                <div class="text-3xl font-black text-[#031636]">+5,000</div>
                <div class="text-slate-500 font-medium mt-1">فني وصنايعي معتمد</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-xl border-t-4 border-[#fd7613]">
                <div class="text-3xl font-black text-[#031636]">+15,000</div>
                <div class="text-slate-500 font-medium mt-1">طلب صيانة تم بنجاح</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-xl border-t-4 border-[#fd7613]">
                <div class="text-3xl font-black text-[#fd7613]">4.9 / 5</div>
                <div class="text-slate-500 font-medium mt-1">تقييم العملاء للخدمات</div>
            </div>
        </div>
    </div>

    <section class="py-20 container mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <h2 class="text-3xl font-black text-[#031636] mb-4">كل التخصصات اللي تحتاجها لبيتك</h2>
            <p class="text-slate-500 text-base">اختر التخصص ونزل طلبك وسيب الباقي على صنايعية أوستاوي المحترفين</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">🚰</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">أعمال السباكة</h3>
                <p class="text-slate-500 text-sm leading-relaxed">تصليح تسريبات المياه، تركيب خلاطات، وتأسيس شبكات الصرف الصحي بالكامل.</p>
            </div>
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">🔌</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">كهرباء منازل</h3>
                <p class="text-slate-500 text-sm leading-relaxed">صيانة وتأسيس شبكات الكهرباء، تركيب الإضاءة، وإصلاح أعطال اللوحات بأمان.</p>
            </div>
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">❄</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">تكييف وتبريد</h3>
                <p class="text-slate-500 text-sm leading-relaxed">شحن فريون التكييفات، غسيل الفلاتر، صيانة الثلاجات والأجهزة المنزلية.</p>
            </div>
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">🎨</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">نقاشة ودهانات</h3>
                <p class="text-slate-500 text-sm leading-relaxed">تجديد دهانات الشقق، تركيب ورق الحائط، ومعالجة الرطوبة والتشققات تماماً.</p>
            </div>
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">🪚</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">نجارة وصيانة أثاث</h3>
                <p class="text-slate-500 text-sm leading-relaxed">تصليح الأبواب والشبابيك، وتركيب المطابخ وغرف النوم باحترافية وسرعة.</p>
            </div>
            <div class="group bg-white p-6 rounded-2xl border border-slate-100 hover:border-[#fd7613] hover:shadow-2xl transition-all cursor-pointer">
                <div class="w-14 h-14 mb-4 bg-[#fff4e6] text-[#fd7613] rounded-xl flex items-center justify-center text-2xl group-hover:bg-[#fd7613] group-hover:text-white transition-all">🛠</div>
                <h3 class="text-xl font-bold text-[#031636] mb-2">صيانة أجهزة منزلية</h3>
                <p class="text-slate-500 text-sm leading-relaxed">تصليح الغسالات، البوتاجازات، والسخانات فوراً داخل منزلك دون نقل الجهاز.</p>
            </div>
        </div>
    </section>

    <section class="py-20 bg-slate-50">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <div class="space-y-6 text-right">
                    <span class="px-3 py-1.5 bg-amber-100 text-amber-800 rounded-full text-xs font-bold">لأصحاب المنازل</span>
                    <h3 class="text-2xl md:text-3xl font-black text-[#031636]">إزاي أوستاوي بيضمن حقك كعميل؟</h3>
                    <p class="text-slate-500 leading-relaxed">هدفنا الأساسي حمايتك من الاستغلال المادي وتقديم خدمة تليق ببيتك:</p>
                    <ul class="space-y-4 pr-0">
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>نظام عروض الأسعار:</strong> الفنيين بيتنافسوا على طلبك وبيقدموا عروض أسعار مختلفة تختار منها براحتك.</div></li>
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>تتبع الفني على الخريطة:</strong> هتشوف الفنيين المتاحين والقريبين من موقعك الجغرافي حالياً.</div></li>
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>تقييمات حقيقية:</strong> اختار الصنايعي المناسب بناءً على تقييمات جيرانه اللي جربوه قبلك.</div></li>
                    </ul>
                    <div class="pt-2">
                        <a href="/Home/MapView" class="px-6 py-3 bg-[#031636] text-white rounded-xl font-bold hover:bg-slate-800 transition-colors inline-block">اطلب فني على الخريطة الآن</a>
                    </div>
                </div>
                <div class="text-center">
                    <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=500&q=80" class="rounded-2xl shadow-xl max-h-[350px] mx-auto object-cover" alt="Clients">
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <div class="space-y-6 text-right md:order-2">
                    <span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-xs font-bold">للصنايعية والفنيين</span>
                    <h3 class="text-2xl md:text-3xl font-black text-[#031636]">عايز تزود دخلك وتلاقي زباين أكتر؟</h3>
                    <p class="text-slate-500 leading-relaxed">لو أنت أسطى شاطر وملتزم في مجالك، أوستاوي هيفتحلك باب رزق وشغل مستمر كل يوم:</p>
                    <ul class="space-y-4 pr-0">
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>شغل في منطقتك:</strong> هيجيلك إشعارات بالطلبات القريبة من مكان سكنك ومحيطك فقط.</div></li>
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>حدد سعرك بنفسك:</strong> أنت اللي بتحدد السعر المناسب لكل عطل وتقدمه للعميل بكل شفافية.</div></li>
                        <li class="flex items-start gap-3"><span class="text-green-500 font-bold">✔</span> <div><strong>ابني سمعتك الرقمية:</strong> كل ما تاخد تقييمات عالية، زباين أكتر هتطلبك بالاسم وتثق فيك.</div></li>
                    </ul>
                    <div class="pt-2">
                        <a href="/Account/Register?role=worker" class="px-6 py-3 bg-[#fd7613] text-white rounded-xl font-bold hover:bg-[#9c4400] transition-colors inline-block">سجل حسابك كفني مجاناً</a>
                    </div>
                </div>
                <div class="text-center md:order-1">
                    <img src="https://images.unsplash.com/photo-1541534741688-6078c6bfb5c5?auto=format&fit=crop&w=500&q=80" class="rounded-2xl shadow-xl max-h-[350px] mx-auto object-cover" alt="Workers">
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-slate-50 text-center">
        <div class="container mx-auto px-6">
            <h2 class="text-3xl font-black text-[#031636] mb-12">الموضوع كله بيخلص في 3 خطوات</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-[#fd7613] text-white font-black rounded-full flex items-center justify-center mx-auto mb-4 text-lg shadow-md">1</div>
                    <h4 class="text-lg font-bold text-[#031636] mb-2">اكتب مشكلتك</h4>
                    <p class="text-slate-500 text-sm leading-relaxed">حدد تخصص العطل (سباكة، كهرباء..) واكتب شرح بسيط للمشكلة وحدد مكانك.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-[#fd7613] text-white font-black rounded-full flex items-center justify-center mx-auto mb-4 text-lg shadow-md">2</div>
                    <h4 class="text-lg font-bold text-[#031636] mb-2">قارن العروض</h4>
                    <p class="text-slate-500 text-sm leading-relaxed">هيصلك عروض أسعار مباشرة من كذا صنايعي، قارن التقييمات والسعر واختار الأنسب.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-[#fd7613] text-white font-black rounded-full flex items-center justify-center mx-auto mb-4 text-lg shadow-md">3</div>
                    <h4 class="text-lg font-bold text-[#031636] mb-2">استلم الشغل وقيم</h4>
                    <p class="text-slate-500 text-sm leading-relaxed">الفني هيجيلك يخلص العطل، وبعد ما يخلص هتعمله تقييم على الموقع لمساعدة الباقيين.</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container mx-auto px-6 my-16">
        <div class="bg-[#031636] text-white p-8 md:p-12 rounded-3xl border-r-8 border-[#fd7613] shadow-2xl">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
                <div class="md:col-span-8 text-right">
                    <h3 class="text-2xl md:text-3xl font-black mb-2">جاهز تبدأ تجربتك مع أوستاوي؟</h3>
                    <p class="text-slate-400 m-0 text-sm md:text-base">انضم لينا النهاردة وسجل حسابك مجاناً سواء كنت بتدور على صنايعي أو فني وعايز تزود دخلك.</p>
                </div>
                <div class="md:col-span-4 text-center md:text-left">
                    <a href="/Account/Register" class="px-8 py-3.5 bg-[#fd7613] text-white rounded-xl font-bold hover:bg-[#9c4400] transition-colors text-base inline-block">إنشاء حساب جديد</a>
                </div>
            </div>
        </div>
    </div>

    <div class="h-8"></div>

</div>