@{
    ViewData["Title"] = "تفاصيل الطلب";
    var request = ViewBag.Request as Ostawy.Models.JobRequest;
    var bids = ViewBag.Bids as List<dynamic> ?? new();
}

<div class="max-w-4xl mx-auto px-4 py-8">
    <a href="/Home/Index" class="inline-flex items-center gap-1 text-sm text-orange-600 font-bold mb-6 hover:underline">
        <span class="material-symbols-outlined text-base">arrow_forward</span>
        الرجوع للطلبات
    </a>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 mb-6">
        <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-bold px-2 py-1 rounded-full @(request.Status == "Open" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500")">
                @(request.Status == "Open" ? "مفتوح" : "مغلق")
            </span>
        </div>
        <h1 class="text-xl font-bold text-slate-900 mb-2">@request.Description</h1>
        <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-3">
            <span>📍 @request.Area</span>
            @if (request.CustomerPrice.HasValue)
            {
                <span>💰 السعر: <strong class="text-green-600">@request.CustomerPrice.Value.ToString("N0") ج.م</strong></span>
            }
            else
            {
                <span>💰 السعر: <strong class="text-orange-600">قابل للتفاوض</strong></span>
            }
        </div>
    </div>

    <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined fill text-orange-500">offer</span>
        العروض المقدمة
        <span class="text-sm font-normal text-gray-400">(@bids.Count عرض)</span>
    </h2>

    @if (bids.Count == 0)
    {
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <span class="material-symbols-outlined text-5xl text-gray-300 mb-3">handyman</span>
            <p class="font-bold text-slate-700">لا توجد عروض حتى الآن</p>
            <p class="text-sm text-gray-400">انتظر حتى يقدم الفنيين عروضهم على طلبك</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var bid in bids)
            {
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-center gap-3 flex-1 min-w-0">
                            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="text-orange-600 font-black text-lg">@(bid.WorkerName?.Substring(0, 1) ?? "ف")</span>
                            </div>
                            <div class="min-w-0">
                                <a href="/Home/WorkerProfile/@bid.WorkerId" class="font-bold text-slate-900 hover:text-orange-600 transition-colors">
                                    @bid.WorkerName
                                </a>
                                <div class="flex items-center gap-2 text-xs text-gray-500 mt-0.5">
                                    <span>@bid.WorkerSpecialty</span>
                                    <span>⭐ @(bid.WorkerRating?.ToString("F1") ?? "5.0")</span>
                                    <span>(@(bid.WorkerReviews ?? 0) تقييم)</span>
                                </div>
                            </div>
                        </div>
                        <div class="text-left flex-shrink-0">
                            <div class="text-lg font-black text-green-600">@(bid.OfferPrice?.ToString("N0") ?? "0") ج.م</div>
                        </div>
                    </div>

                    @if (request.Status == "Open")
                    {
                        <div class="flex items-center gap-2 mt-4 pt-3 border-t border-gray-100">
                            <button onclick="acceptBid(@bid.BidId)" class="flex-1 py-2.5 bg-green-500 text-white rounded-xl text-sm font-bold hover:bg-green-600 transition-all">
                                قبول العرض ✅
                            </button>
                            <button onclick="showCounterOffer(@bid.BidId, @(bid.OfferPrice ?? 0))" class="flex-1 py-2.5 bg-orange-50 text-orange-600 rounded-xl text-sm font-bold hover:bg-orange-100 transition-all">
                                اقتراح سعر جديد 💬
                            </button>
                            <a href="/Chat?requestId=@request.Id" class="px-4 py-2.5 bg-blue-50 text-blue-600 rounded-xl text-sm font-bold hover:bg-blue-100 transition-all flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">chat</span>
                                شات
                            </a>
                        </div>
                    }
                    else if (bid.Status == "Accepted")
                    {
                        <div class="mt-4 pt-3 border-t border-gray-100">
                            <span class="text-sm font-bold text-green-600">✅ تم قبول هذا العرض</span>
                            <a href="/Chat?requestId=@request.Id" class="mr-3 px-4 py-2 bg-blue-50 text-blue-600 rounded-xl text-sm font-bold hover:bg-blue-100 transition-all">
                                التواصل مع الفني 💬
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<script>
function acceptBid(bidId) {
    if (!confirm('هل أنت متأكد من قبول هذا العرض؟')) return;
    fetch('/Home/AcceptBid', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'bidId=' + bidId
    })
    .then(r => r.json())
    .then(result => {
        alert(result.message);
        if (result.success) location.reload();
    });
}

function showCounterOffer(bidId, currentPrice) {
    const newPrice = prompt('ادخل السعر الجديد اللي عايز تدفعه (ج.م):', currentPrice);
    if (!newPrice || parseFloat(newPrice) <= 0) return;

    fetch('/Home/CounterOffer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'bidId=' + bidId + '&newPrice=' + newPrice
    })
    .then(r => r.json())
    .then(result => {
        alert(result.message);
        if (result.success) location.reload();
    });
}
</script>
