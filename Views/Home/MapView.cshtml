@model IEnumerable<Ostawy.Models.User>
@{
    ViewData["Title"] = "خريطة الفنيين - أوستاوي";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
    #mapContainer { height: calc(100vh - 64px); }
    #map { height: 100%; width: 100%; }
    #sidePanel { height: calc(100vh - 64px); overflow-y: auto; }
    @@media (max-width: 767px) {
        #mapContainer { height: 50vh; }
        #sidePanel { height: 50vh; }
    }
    .leaflet-popup-content-wrapper { border-radius: 16px !important; padding: 4px; }
    .leaflet-popup-content { margin: 12px 16px; }
    .worker-card { transition: all 0.2s ease; }
    .worker-card:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
</style>

<div id="mapContainer" class="flex flex-col md:flex-row">
    <div class="flex-1 relative">
        <div id="map"></div>
        <div class="absolute top-4 right-4 z-10 bg-white/95 backdrop-blur-sm px-3 py-2 rounded-xl shadow-md text-xs font-bold text-slate-700 border border-gray-100 flex items-center gap-1.5">
            <span class="material-symbols-outlined text-orange-500 text-base">touch_app</span>
            اضغط على الخريطة لتحديد مكان المشكلة
        </div>
    </div>

    <div id="sidePanel" class="w-full md:w-[380px] bg-white border-r border-gray-100 flex flex-col flex-shrink-0">

        <div id="createRequestSection" class="p-5 space-y-4 flex-grow">
            <div class="flex items-center gap-2.5 mb-2">
                <div class="w-9 h-9 bg-gradient-to-br from-orange-500 to-amber-500 rounded-xl flex items-center justify-center shadow-sm">
                    <span class="material-symbols-outlined text-white fill">add_location</span>
                </div>
                <div>
                    <h2 class="font-black text-base text-slate-900">انشر مشكلتك</h2>
                    <p class="text-[11px] text-gray-400">حدد الموقع واكتب التفاصيل</p>
                </div>
            </div>

            <div class="bg-slate-50 rounded-xl p-3 grid grid-cols-2 gap-2 text-[11px]">
                <div class="text-gray-500"><span class="font-bold text-slate-700">خط العرض:</span> <span id="displayLat" class="font-mono">لم يحدد</span></div>
                <div class="text-gray-500"><span class="font-bold text-slate-700">خط الطول:</span> <span id="displayLng" class="font-mono">لم يحدد</span></div>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1.5">نوع الخدمة</label>
                <select id="jobCategory" class="w-full rounded-xl border-2 border-gray-100 p-3 bg-white text-sm outline-none focus:border-orange-400 focus:bg-orange-50/30 transition-all">
                    <option value="plumbing">🔧 سباكة</option>
                    <option value="electric">⚡ كهرباء</option>
                    <option value="ac">❄️ تكييف وتبريد</option>
                    <option value="paint">🎨 دهانات ونقاشة</option>
                    <option value="carpentry">🪚 نجارة</option>
                    <option value="tiles">🧱 سيراميك وبلاط</option>
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1.5">اشرح المشكلة للفنيين</label>
                <textarea id="jobDescription" rows="3" placeholder="مثال: ماسورة مكسورة في المطبخ وبتنزل مية..." class="w-full rounded-xl border-2 border-gray-100 p-3 bg-white text-sm outline-none focus:border-orange-400 focus:bg-orange-50/30 transition-all"></textarea>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1.5 flex items-center justify-between">
                    <span>السعر المعروض (ج.م)</span>
                    <span class="text-[10px] text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">اختياري</span>
                </label>
                <input id="customerPrice" type="number" min="1" placeholder="مثلاً: 500 أو اتركه فارغاً" class="w-full rounded-xl border-2 border-gray-100 p-3 bg-white text-sm outline-none focus:border-orange-400 focus:bg-orange-50/30 transition-all" />
            </div>

            <button onclick="submitJobRequest()" id="submitJobBtn" class="w-full py-3.5 bg-gradient-to-l from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white rounded-xl font-black text-sm shadow-lg shadow-orange-500/20 transition-all active:scale-[0.98]">
                <span class="flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined fill">rocket_launch</span>
                    أنشئ المزاد وانشر الطلب
                </span>
            </button>
        </div>

        <div id="waitingBidsSection" class="hidden p-5 space-y-4 flex-grow bg-gradient-to-b from-slate-50 to-white">
            <div class="bg-white rounded-2xl p-5 border border-orange-100 shadow-sm text-center">
                <div class="w-3 h-3 bg-orange-500 rounded-full mx-auto mb-3 animate-ping"></div>
                <h2 class="font-black text-base text-slate-900">في انتظار عروض الأوستاية...</h2>
                <p class="text-xs text-gray-500 mt-2">الفنيون القريبون يراجعون طلبك الآن ويجهزون عروضهم.</p>
            </div>

            <h3 class="font-bold text-sm text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-orange-500 fill">gavel</span>
                العروض المقدمة لك:
            </h3>
            <div id="bidsList" class="space-y-3"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let map;
    let selectedLat = null;
    let selectedLng = null;
    let currentRequestId = null;
    let bidsInterval = null;
    let currentMarker = null;
    let workersMarkers = [];

    const currentClientId = @(ViewBag.ClientId ?? 5);
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    document.addEventListener("DOMContentLoaded", function () {
        map = L.map('map', { zoomControl: false }).setView([30.0444, 31.2357], 13);
        L.control.zoom({ position: 'bottomleft' }).addTo(map);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap',
            maxZoom: 19
        }).addTo(map);

        map.on('click', function(e) {
            setTargetLocation(e.latlng.lat, e.latlng.lng);
        });

        loadWorkersOnMap();
        locateUser();
    });

    function loadWorkersOnMap() {
        fetch('/Home/GetWorkersJson')
            .then(r => r.json())
            .then(workers => {
                workers.forEach(w => {
                    const icon = L.divIcon({
                        className: '',
                        html: `<div style="background:linear-gradient(135deg,#f97316,#f59e0b);border:3px solid white;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(249,115,22,0.4);cursor:pointer;"><span style="color:white;font-weight:900;font-size:13px;">${w.avatar}</span></div>`,
                        iconSize: [36, 36],
                        iconAnchor: [18, 18],
                        popupAnchor: [0, -18]
                    });

                    const marker = L.marker([w.lat, w.lng], { icon }).addTo(map);
                    marker.bindPopup(`
                        <div style="min-width:200px;text-align:right;font-family:'Noto Sans Arabic',sans-serif;">
                            <div style="font-weight:900;font-size:15px;color:#0f172a;">${w.name}</div>
                            <div style="font-size:12px;color:#64748b;margin:4px 0;">${w.specialty}</div>
                            <div style="display:flex;gap:8px;font-size:12px;margin:6px 0;">
                                <span style="color:#f59e0b;">⭐ ${w.rating?.toFixed(1)}</span>
                                <span style="color:#64748b;">(${w.reviews} تقييم)</span>
                            </div>
                            <div style="font-weight:900;font-size:16px;color:#16a34a;">${w.price} ج.م <span style="font-weight:400;font-size:11px;color:#64748b;">/ اليومية</span></div>
                            <a href="/Home/WorkerProfile/${w.id}" style="display:block;margin-top:8px;padding:6px;background:#f8fafc;border-radius:8px;font-size:11px;color:#f97316;font-weight:700;text-decoration:none;text-align:center;">عرض الملف الشخصي</a>
                        </div>
                    `);
                    workersMarkers.push(marker);
                });
            });
    }

    function locateUser() {
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(pos => {
            setTargetLocation(pos.coords.latitude, pos.coords.longitude);
            map.setView([pos.coords.latitude, pos.coords.longitude], 15);
        });
    }

    function setTargetLocation(lat, lng) {
        selectedLat = lat;
        selectedLng = lng;
        document.getElementById('displayLat').textContent = lat.toFixed(4);
        document.getElementById('displayLng').textContent = lng.toFixed(4);

        if (currentMarker) map.removeLayer(currentMarker);
        currentMarker = L.marker([lat, lng], {
            icon: L.divIcon({
                className: '',
                html: `<div style="background:#ef4444;border:3px solid white;border-radius:50%;width:28px;height:28px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(239,68,68,0.5);"><span style="color:white;font-size:16px;">📍</span></div>`,
                iconSize: [28, 28],
                iconAnchor: [14, 14]
            })
        }).addTo(map).bindPopup('<p style="font-family:Noto Sans Arabic;font-weight:700;padding:2px;text-align:center;font-size:12px;">📍 مكان المشكلة هنا</p>').openPopup();
    }

    async function submitJobRequest() {
        if (!selectedLat || !selectedLng) {
            return alert("من فضلك حدد مكان المشكلة على الخريطة أولاً!");
        }
        const desc = document.getElementById('jobDescription').value.trim();
        const category = document.getElementById('jobCategory').value;
        const price = document.getElementById('customerPrice').value;

        if (!desc) {
            return alert("من فضلك اكتب وصفاً للمشكلة.");
        }

        const btn = document.getElementById('submitJobBtn');
        btn.innerHTML = '<span class="flex items-center justify-center gap-2"><span class="material-symbols-outlined animate-spin">progress_activity</span> جاري النشر...</span>';
        btn.disabled = true;

        try {
            const response = await fetch('/Bidding/CreateJobRequest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({
                    clientId: currentClientId,
                    description: desc,
                    category: category,
                    customerPrice: price ? parseFloat(price) : null,
                    lat: selectedLat,
                    lng: selectedLng
                })
            });
            const result = await response.json();
            if (result.success) {
                currentRequestId = result.requestId;
                document.getElementById('createRequestSection').classList.add('hidden');
                document.getElementById('waitingBidsSection').classList.remove('hidden');
                startCheckingForBids();
            }
        } catch (err) {
            console.error(err);
            alert("حدث خطأ أثناء النشر");
            btn.innerHTML = '<span class="flex items-center justify-center gap-2"><span class="material-symbols-outlined fill">rocket_launch</span> أنشئ المزاد وانشر الطلب</span>';
            btn.disabled = false;
        }
    }

    function startCheckingForBids() {
        bidsInterval = setInterval(async () => {
            if (!currentRequestId) return;
            try {
                const res = await fetch(`/Bidding/GetBidsForRequest?requestId=${currentRequestId}`);
                const bids = await res.json();
                renderBidsList(bids);
            } catch (err) { console.error(err); }
        }, 4000);
    }

    function renderBidsList(bids) {
        const list = document.getElementById('bidsList');
        list.innerHTML = '';
        if (bids.length === 0) {
            list.innerHTML = '<p class="text-xs text-center text-gray-400 py-6">لم يصل أي عرض بعد.. انتظر قليلاً</p>';
            return;
        }
        bids.forEach(bid => {
            const card = document.createElement('div');
            card.className = 'worker-card bg-white rounded-xl p-4 border border-gray-100 shadow-sm';
            card.innerHTML = `
                <div class="flex justify-between items-start mb-2">
                    <div class="flex items-center gap-2">
                        <div class="w-9 h-9 bg-orange-100 rounded-lg flex items-center justify-center">
                            <span class="font-black text-orange-600 text-sm">${(bid.workerName || 'ف')[0]}</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-sm text-slate-900">${bid.workerName || 'فني'}</h4>
                            <p class="text-amber-500 font-bold text-[11px]">⭐ ${(bid.workerRating || 5).toFixed(1)}</p>
                        </div>
                    </div>
                    <div class="text-left">
                        <span class="text-[10px] text-gray-400 block">عرض سعر</span>
                        <span class="font-black text-orange-600 text-base">${bid.offerPrice} ج.م</span>
                    </div>
                </div>
                <div class="flex gap-2 mt-3">
                    <button onclick="acceptWorkerBid(${bid.bidId})" class="flex-1 py-2.5 bg-gradient-to-l from-emerald-500 to-green-500 text-white font-bold rounded-lg text-xs hover:shadow-lg transition-all">قبول العرض ✅</button>
                    <a href="/Chat?requestId=${currentRequestId}" class="px-4 py-2.5 bg-blue-50 text-blue-600 font-bold rounded-lg text-xs hover:bg-blue-100 transition-all flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">chat</span>
                        شات
                    </a>
                </div>
            `;
            list.appendChild(card);
        });
    }

    async function acceptWorkerBid(bidId) {
        if (!confirm("هل أنت متأكد إنك موافق على عرض الأسطى ده؟")) return;
        try {
            const res = await fetch(`/Bidding/AcceptBid?bidId=${bidId}`, { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                clearInterval(bidsInterval);
                alert(result.message);
                location.reload();
            }
        } catch (err) { console.error(err); }
    }
</script>
}
