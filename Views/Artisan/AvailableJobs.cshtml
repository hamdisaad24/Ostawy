@model IEnumerable<Ostawy.Models.JobRequest>

@{
    ViewData["Title"] = "الطلبات المتاحة";
    // جلب قائمة العروض السابقة لمنع التكرار
    var submittedJobIds = ViewBag.SubmittedJobIds as List<Guid> ?? new List<Guid>();
}

<!-- استدعاء خطوط وثيم المشروع -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
<!-- استخدام أيقونات البوتستراب -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f5f7fa;
        font-family: 'Cairo', sans-serif;
        direction: rtl;
        text-align: right;
    }

    .job-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .job-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(26, 43, 76, 0.08);
    }

    .job-title {
        color: #1a2b4c;
        font-weight: 700;
        font-size: 1.25rem;
    }

    .job-meta {
        color: #64748b;
        font-size: 0.9rem;
    }

    .phone-badge {
        background-color: #e0f2fe;
        color: #0369a1;
        border-radius: 8px;
        padding: 10px 15px;
        font-weight: 600;
        font-size: 1rem;
        display: inline-block;
        border: 1px solid #bae6fd;
    }

    .btn-submit-bid {
        background-color: #ef6c00;
        color: white;
        font-weight: bold;
        border-radius: 8px;
        border: none;
    }

    .btn-submit-bid:hover {
        background-color: #d86200;
        color: white;
    }
</style>

<div class="container mt-5 mb-5 pt-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="fw-bold" style="color: #1a2b4c;">الطلبات المتاحة في تخصصك</h2>
            <p class="text-muted">اختر الطلب المناسب لك وتواصل مع العميل مباشرة أو قدم عرض سعرك.</p>
        </div>
    </div>

    <!-- رسائل النجاح أو الخطأ -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var job in Model)
            {
                bool hasSubmitted = submittedJobIds.Contains(job.Id);

                string phoneNumber = "رقم الهاتف غير متاح";
                try {
                    phoneNumber = ViewBag.PhoneNumber ?? "رقم الهاتف غير متاح";
                } catch { }

                <div class="col-lg-6 col-md-12 mb-4">
                    <div class="job-card p-4 h-100 d-flex flex-column">
                        
                        <div class="mb-3">
                            <h3 class="job-title">@job.Description</h3>
                            <div class="job-meta mt-2 d-flex gap-3 flex-wrap">
                                <span><i class="bi bi-tools"></i> رقم الفئة: @job.ProfessionId</span>
                                <span><i class="bi bi-cash-stack"></i> الميزانية: @job.EstimatedPrice ج.م</span>
                                <span><i class="bi bi-clock"></i> نشر منذ: @job.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>

                        <!-- إظهار رقم هاتف العميل -->
                        <div class="mb-4">
                            <div class="phone-badge w-100 text-center">
                                <i class="bi bi-telephone-fill me-2"></i> هاتف العميل: <span class="ms-1" dir="ltr">@phoneNumber</span>
                            </div>
                        </div>

                        <div class="mt-auto">
                            @if (hasSubmitted)
                            {
                                <button class="btn btn-secondary w-100 fw-bold disabled" style="border-radius: 8px;">
                                    <i class="bi bi-check2-all me-1"></i> لقد قمت بتقديم عرض مسبقاً
                                </button>
                            }
                            else
                            {
                                <form asp-action="SubmitBid" asp-controller="Artisan" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="JobRequestId" value="@job.Id" />
                                    
                                    <div class="input-group mb-3" style="direction: ltr;">
                                        <span class="input-group-text bg-light text-muted border-end-0 rounded-start">ج.م</span>
                                        <input type="number" name="OfferPrice" class="form-control text-end border-start-0" placeholder="أدخل السعر المقترح" required min="1" style="border-radius: 0 8px 8px 0;" />
                                    </div>
                                    
                                    <div class="mb-3">
                                        <textarea name="Note" class="form-control" placeholder="اكتب ملاحظة أو تفاصيل عرضك للعميل (اختياري)..." rows="2" style="border-radius: 8px;"></textarea>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-submit-bid w-100 py-2">
                                        <i class="bi bi-send-fill me-1"></i> تقديم عرض سعر
                                    </button>
                                </form>
                            }
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-muted">لا توجد طلبات متاحة في تخصصك حالياً</h4>
                <p>يرجى العودة لاحقاً أو التحقق من تحديث الصفحة.</p>
            </div>
        }
    </div>
</div>