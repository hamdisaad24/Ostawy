@model IEnumerable<Ostawy.Models.JobRequest>

@{
    ViewData["Title"] = "الطلبات المتاحة - أوستاوي";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold" style="color: #031636;">الطلبات المتاحة الآن 🛠️</h3>
            <p class="text-muted small m-0">دي الطلبات اللي العملاء منزلاها دلوقتي، اختار الشغلانة المناسبة وقدم عرضك.</p>
        </div>
        <span class="badge bg-dark fs-6 px-3 py-2" style="border-radius: 8px;">عدد الطلبات: @Model.Count()</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4 text-right" style="border-radius: 12px;">
            🎉 @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4 text-right" style="border-radius: 12px;">
            ⚠️ @TempData["Error"]
        </div>
    }

    <div class="row g-3">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted">
                <div class="fs-1 mb-2">☕</div>
                <p>مفيش طلبات مفتوحة حالياً.. ريح شوية واعمل ريفريش كمان شوية!</p>
            </div>
        }
        else
        {
            foreach (var job in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 p-4 text-right d-flex flex-column justify-content-between" style="border-radius: 20px; background: #ffffff;">
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-light text-dark fw-bold px-2 py-2" style="border-radius: 6px;">⚙️ @job.Category?.Name</span>
                                <small class="text-muted" style="font-size: 11px;">@job.CreatedAt.ToString("hh:mm tt")</small>
                            </div>
                            
                            <h6 class="fw-bold text-muted small mb-1">الميزانية المقترحة من العميل:</h6>
                            <p class="fw-black text-success fs-5 mb-3">@job.EstimatedPrice ج.م</p>

                            <h6 class="fw-bold text-muted small mb-1">وصف الطلب:</h6>
                            <p class="text-dark small mb-4" style="line-height: 1.6; min-height: 50px;">
                                @(job.Description.Length > 100 ? job.Description.Substring(0, 97) + "..." : job.Description)
                            </p>
                        </div>

                        <button type="button" class="btn w-100 fw-bold text-white py-2"
                                style="background-color: #031636; border-radius: 10px;"
                                onclick="openBidModal(@job.Id, '@job.Category?.Name', @job.EstimatedPrice)">
                            ⚡ تقديم عرض سعر
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade" id="bidModal" tabindex="-1" aria-labelledby="bidModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 text-right" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light py-3" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="bidModalLabel" style="color: #031636;">تقديم عرض سعر جديد</h5>
                <button type="button" class="btn-close m-0 me-auto" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SubmitBid" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="JobRequestId" id="modalJobRequestId" />

                <div class="modal-body p-4">
                    <div class="mb-3 p-3 rounded-3" style="background-color: #f8fafc;">
                        <span class="small text-muted d-block">القسم المطلـوب:</span>
                        <span class="fw-bold text-dark" id="modalCategoryName"></span>
                        <hr class="my-2 opacity-25">
                        <span class="small text-muted d-block">ميزانية العميل التقريبية:</span>
                        <span class="fw-bold text-success" id="modalEstimatedPrice"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #031636;">عرض السعر الخاص بك (جنية)</label>
                        <input type="number" name="OfferPrice" class="form-control form-control-lg" required placeholder="اكتب سعرك المناسب للشغلانة" style="border-radius: 10px; font-size: 15px;" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold" style="color: #031636;">ملاحظة للعميل (اختياري)</label>
                        <textarea name="Note" rows="3" class="form-control" placeholder="مثال: هكون عندك خلال ساعة ومعايا كل المعدات اللازمة..." style="border-radius: 10px; font-size: 14px;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal" style="border-radius: 10px;">إلغاء</button>
                    <button type="submit" class="btn fw-bold text-white px-4" style="background-color: #fd7613; border-radius: 10px;">🚀 إرسال العرض الآن</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openBidModal(jobId, categoryName, estPrice) {
            $('#modalJobRequestId').val(jobId);
            $('#modalCategoryName').text(categoryName);
            $('#modalEstimatedPrice').text(estPrice + ' ج.م');
            
            var myModal = new bootstrap.Modal(document.getElementById('bidModal'));
            myModal.show();
        }
    </script>
}