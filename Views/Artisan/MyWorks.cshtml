@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "معرض أعمالي - أوستاوي";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container text-right" style="margin-top: 140px; margin-bottom: 60px;">
    
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold" style="color: #031636;">💼 معرض أعمالي السابقة</h3>
            <p class="text-muted small m-0">هنا بتظهر الشغلانات المكتملة والناجحة اللي بتثبت خبرتك للعملاء الجداد.</p>
        </div>
        <button class="btn text-white fw-bold px-4 py-2" style="background-color: #fd7613; border-radius: 10px;" onclick="alert('ميزة إضافة عمل جديد من المعرض قيد التطوير للحسابات الـ PRO!')">
            ➕ إضافة عمل جديد
        </button>
    </div>

    <div class="row g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted">
                <div class="fs-1 mb-2">📸</div>
                <p>لسه مفيش أعمال مضافة في المعرض بتاعك حالياً.</p>
            </div>
        }
        else
        {
            foreach (var work in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden text-right bg-white" style="border-radius: 20px; transition: all 0.3s ease;">
                        
                        <div style="height: 200px; background: #031636; position: relative; display: flex; align-items: center; justify-content: center; color: white;">
                            <div class="text-center">
                                <span class="fs-1 d-block mb-1">🛠️</span>
                                <span class="small opacity-75">معاينة المشروع المكتمل</span>
                            </div>
                            <span class="badge position-absolute top-0 left-0 m-3 text-dark fw-bold" style="background-color: #ffc107; left: 15px; right: auto;">⭐ @work.Rating / 5</span>
                        </div>

                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="fw-bold mb-2" style="color: #031636;">@work.Title</h5>
                                <p class="text-muted small mb-3" style="line-height: 1.6; min-height: 60px;">
                                    @work.Description
                                </p>
                            </div>

                            <div class="border-top pt-3 mt-2">
                                <div class="d-flex justify-content-between align-items-center small">
                                    <span class="text-secondary">👤 العميل: <strong>@work.ClientName</strong></span>
                                    <span class="text-muted">📅 @work.Date</span>
                                </div>
                                <div class="mt-2 text-warning">
                                    @for (int i = 0; i < work.Rating; i++)
                                    {
                                        <span>★</span>
                                    }
                                    @for (int i = work.Rating; i < 5; i++)
                                    {
                                        <span class="text-muted opacity-25">★</span>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(3, 22, 54, 0.08) !important;
    }
</style>