@model IEnumerable<Ostawy.Models.ApplicationUser>

@{
    ViewData["Title"] = "الصنايعية";
}


<div class="container" style="margin-top:120px;margin-bottom:60px">


    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                🛠️ إدارة الصنايعية
            </h2>

            <p class="text-muted">
                متابعة جميع الصنايعية المسجلين في المنصة
            </p>
        </div>


        <div class="badge bg-dark fs-6 p-3">
            العدد : @Model.Count()
        </div>


    </div>



    <div class="row g-4">


        @foreach (var user in Model)
        {


            <div class="col-lg-4 col-md-6">


                <div class="card border-0 shadow-sm rounded-4 h-100">


                    <div class="card-body text-center">


                        <div class="mb-3">

                            <img src="~/images/default-user.png" class="rounded-circle" width="90" height="90" />

                        </div>



                        <h4 class="fw-bold">
                            @user.FullName
                        </h4>


                        <p class="text-muted mb-2">
                            @user.Email
                        </p>



                        <div class="d-flex justify-content-center gap-2 mb-3">


                            <span class="badge bg-success">
                                نشط
                            </span>


                            <span class="badge bg-warning text-dark">
                                PRO
                            </span>


                        </div>



                        <div class="row text-center mb-3">


                            <div class="col">

                                <h5 class="fw-bold">
                                    0
                                </h5>

                                <small class="text-muted">
                                    طلبات
                                </small>

                            </div>



                            <div class="col">

                                <h5 class="fw-bold">
                                    0
                                </h5>

                                <small class="text-muted">
                                    تقييمات
                                </small>

                            </div>



                            <div class="col">

                                <h5 class="fw-bold">
                                    0
                                </h5>

                                <small class="text-muted">
                                    أعمال
                                </small>

                            </div>


                        </div>



                        <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-primary w-100 rounded-3">


                            عرض الملف


                        </a>


                    </div>


                </div>


            </div>



        }


    </div>


</div>