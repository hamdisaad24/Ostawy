@model IEnumerable<Ostawy.Models.ApplicationUser>

@{
    ViewData["Title"] = "العملاء";
}



<div class="container" style="margin-top:120px">


    <div class="d-flex justify-content-between mb-4">


        <div>

            <h2 class="fw-bold">
                👥 العملاء
            </h2>


            <p class="text-muted">
                إدارة حسابات العملاء وطلبات الخدمة
            </p>

        </div>



        <div class="badge bg-dark p-3">
            العدد : @Model.Count()
        </div>


    </div>



    <div class="row g-4">


        @foreach (var user in Model)
        {


            <div class="col-lg-4 col-md-6">


                <div class="card border-0 shadow-sm rounded-4">


                    <div class="card-body text-center">



                        <img src="~/images/default-user.png" width="90" height="90" class="rounded-circle mb-3" />



                        <h4 class="fw-bold">
                            @user.FullName
                        </h4>



                        <p class="text-muted">
                            @user.Email
                        </p>



                        <span class="badge bg-primary">
                            عميل
                        </span>



                        <hr />


                        <div class="row">


                            <div class="col">

                                <h5>
                                    0
                                </h5>

                                <small>
                                    طلبات
                                </small>

                            </div>



                            <div class="col">

                                <h5>
                                    0
                                </h5>

                                <small>
                                    طلبات مكتملة
                                </small>

                            </div>


                        </div>



                        <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-dark w-100 mt-3">

                            عرض الملف

                        </a>


                    </div>


                </div>


            </div>


        }


    </div>


</div>