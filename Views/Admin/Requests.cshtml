@model IEnumerable<Ostawy.Models.JobRequest>

@{
    ViewData["Title"] = "إدارة الطلبات";
}

<style>
    :root {
        --primary: #031636;
        --secondary: #fd7613;
        --success: #16a34a;
        --danger: #dc2626;
        --warning: #f59e0b;
    }

    .page-container {
        max-width: 1300px;
        margin: 120px auto 60px;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 35px;
    }

    .page-title {
        color: var(--primary);
        font-weight: 900;
    }

    .table-card {
        background: white;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    thead {
        background: var(--primary);
        color: white;
    }

    th {
        text-align: center;
        white-space: nowrap;
        padding: 18px !important;
    }

    td {
        text-align: center;
        vertical-align: middle;
        padding: 18px !important;
    }

    tbody tr:hover {
        background: #fafafa;
    }

    .status-open {
        background: rgba(22,163,74,.15);
        color: var(--success);
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: bold;
    }

    .status-accepted {
        background: rgba(245,158,11,.15);
        color: var(--warning);
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: bold;
    }

    .status-closed {
        background: rgba(220,38,38,.15);
        color: var(--danger);
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: bold;
    }

    .status-cancelled {
        background: rgba(108,117,125,.15);
        color: #6c757d;
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: bold;
    }

    .price {
        color: var(--secondary);
        font-weight: bold;
        font-size: 16px;
    }

    .desc-cell {
        text-align: right;
        max-width: 350px;
    }

    .btn-delete {
        background: var(--danger);
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        text-decoration: none;
    }

    .btn-delete:hover {
        background: #b91c1c;
        color: white;
    }

    .empty {
        text-align: center;
        padding: 70px;
    }
</style>

<div class="page-container">

    <div class="page-header">
        <div>
            <h2 class="page-title">إدارة الطلبات</h2>
            <p class="text-muted">
                جميع طلبات العملاء داخل النظام.
            </p>
        </div>
    </div>

    <div class="table-card">

        @if (Model.Any())
        {
            <table class="table table-hover align-middle mb-0">

                <thead>

                <tr>
                    <th>رقم الطلب</th>
                    <th>العميل</th>
                    <th>التخصص</th>
                    <th>الوصف</th>
                    <th>الميزانية</th>
                    <th>الحالة</th>
                    <th>تاريخ الإنشاء</th>
                    <th>العمليات</th>
                </tr>

                </thead>

                <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.Id.ToString().Substring(0,8)
                        </td>

                        <td>
                            @item.User?.FullName
                        </td>

                        <td>
                            @item.Profession?.Name
                        </td>

                        <td class="desc-cell">
                            @item.Description
                        </td>

                        <td>
                            <span class="price">
                                @item.EstimatedPrice.ToString("N0") ج.م
                            </span>
                        </td>

                        <td>

                            @switch (item.Status)
                            {
                                case "Open":
                                    <span class="status-open">
                                        مفتوح
                                    </span>
                                    break;

                                case "Accepted":
                                    <span class="status-accepted">
                                        تم قبول عرض
                                    </span>
                                    break;

                                case "Closed":
                                    <span class="status-closed">
                                        مغلق
                                    </span>
                                    break;

                                case "Cancelled":
                                    <span class="status-cancelled">
                                        ملغي
                                    </span>
                                    break;

                                default:
                                    <span>
                                        @item.Status
                                    </span>
                                    break;
                            }

                        </td>

                        <td>
                            @item.CreatedAt.ToString("yyyy/MM/dd hh:mm tt")
                        </td>

                        <td>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn-delete">

                                حذف

                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>
        }
        else
        {
            <div class="empty">
                <h4>لا توجد طلبات حتى الآن.</h4>
            </div>
        }

    </div>

</div>