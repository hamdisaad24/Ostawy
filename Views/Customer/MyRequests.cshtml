@model IEnumerable<Ostawy.Models.JobRequest>

@{
    ViewData["Title"] = "طلباتي الحالية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="direction: rtl; text-align: right; padding-top: 140px; padding-bottom: 60px; max-width: 1000px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0" style="color: #031636;">📋 طلبات الصيانة الخاصة بي</h3>

        <a asp-action="CreateRequest"
           class="btn text-white fw-bold px-4 py-2"
           style="background-color: #fd7613; border-radius: 10px;">
            ➕ اطلب أسطى جديد
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="p-5 text-center border bg-white shadow-sm" style="border-radius:16px;">
            <p class="fs-4 text-muted mb-3">
                أنت لسه منزلتش أي طلبات صيانة لحد دلوقتي! 🤔
            </p>

            <a asp-action="CreateRequest"
               class="btn btn-outline-primary"
               style="border-radius:8px;">
                اعمل أول طلب ليك دلوقتي
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">

            @foreach (var request in Model)
            {
                <div class="col-md-6">

                    <div class="p-4 bg-white border rounded-4 shadow-sm position-relative h-100 d-flex flex-column justify-content-between"
                         style="border-right:5px solid
                         @(
                            request.Status == "Open" ? "#fd7613" :
                            request.Status == "Assigned" ? "#0d6efd" :
                            request.Status == "Completed" ? "#198754" :
                            "#64748b"
                         ) !important;">

                        <div>

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <h5 class="fw-bold m-0" style="color:#fd7613;">
                                    🛠️ @request.Profession?.Name
                                </h5>

                                @if (request.Status == "Open")
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2"
                                          style="border-radius:6px;">
                                        ⏳ في انتظار العروض
                                    </span>
                                }
                                else if (request.Status == "Assigned")
                                {
                                    <span class="badge bg-primary text-white px-3 py-2"
                                          style="border-radius:6px;">
                                        👷 تم اختيار الصنايعي
                                    </span>
                                }
                                else if (request.Status == "Completed")
                                {
                                    <span class="badge bg-success text-white px-3 py-2"
                                          style="border-radius:6px;">
                                        ✅ تم الانتهاء
                                    </span>
                                }
                                else if (request.Status == "Cancelled")
                                {
                                    <span class="badge bg-secondary text-white px-3 py-2"
                                          style="border-radius:6px;">
                                        ❌ ملغي
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark px-3 py-2"
                                          style="border-radius:6px;">
                                        @request.Status
                                    </span>
                                }

                            </div>

                            <p class="text-muted small mb-3">
                                📅 تاريخ النشر:
                                @request.CreatedAt.ToString("yyyy-MM-dd")
                            </p>

                            <div class="bg-light rounded-3 p-3 mb-3">

                                <h6 class="fw-bold text-muted mb-2">
                                    وصف الطلب
                                </h6>

                                <p class="text-dark small mb-0"
                                   style="line-height:1.7; min-height:80px;">
                                    @request.Description
                                </p>

                            </div>

                        </div>

                        <div class="border-top pt-3">

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <span class="fw-bold"
                                      style="color:#031636;">
                                    💰 الميزانية:
                                    @request.EstimatedPrice.ToString("0.##") ج.م
                                </span>

                            </div>

                            @if (request.Status == "Open")
                            {
                                <a asp-action="RequestDashboard"
                                   asp-route-requestId="@request.Id"
                                   class="btn btn-dark w-100 fw-bold py-2"
                                   style="border-radius:10px;">
                                    👁️ متابعة العروض
                                </a>
                            }
                            else if (request.Status == "Assigned")
                            {
                                <a asp-action="RequestDashboard"
                                   asp-route-requestId="@request.Id"
                                   class="btn btn-primary w-100 fw-bold py-2"
                                   style="border-radius:10px;">
                                    👷 متابعة الصنايعي
                                </a>
                            }
                            else if (request.Status == "Completed")
                            {
                                <a asp-action="RequestDashboard"
                                   asp-route-requestId="@request.Id"
                                   class="btn btn-success w-100 fw-bold py-2"
                                   style="border-radius:10px;">
                                    ⭐ عرض التفاصيل
                                </a>
                            }
                            else if (request.Status == "Cancelled")
                            {
                                <button class="btn btn-secondary w-100 fw-bold py-2"
                                        style="border-radius:10px;"
                                        disabled>
                                    ❌ تم إلغاء الطلب
                                </button>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>