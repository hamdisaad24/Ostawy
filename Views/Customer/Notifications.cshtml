@model IEnumerable<Ostawy.Models.JobBid>

@{
    ViewData["Title"] = "الإشعارات";
    string role = ViewBag.UserRole ?? "";
}

<div class="container" style="direction: rtl; text-align: right; max-width: 800px; padding-top: 100px; padding-bottom: 40px;">
    <h3 class="mb-4 fw-bold" style="color: #ff6600;">🔔 الإشعارات الواردة</h3>

    @if (!Model.Any())
    {
        <div class="p-4 text-center border text-muted bg-light" style="border-radius: 8px;">
            لا توجد إشعارات جديدة حالياً.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var bid in Model)
            {
                @if (role == "Client")
                {
                    <!-- إشعار خاص بالعميل فقط -->
                    <div class="p-3 d-flex justify-content-between align-items-center border-bottom bg-white shadow-sm" style="border-radius: 8px; border-right: 4px solid #ff6600;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5">👷</span>
                            <div>
                                <span class="fw-bold">هناك عرض سعر جديد</span> على طلبك (<span class="text-secondary">@bid.JobRequest?.Category?.Name</span>)
                                بقيمة <span class="fw-bold text-success">@bid.OfferPrice جنيه</span>.
                                <br />
                                <small class="text-muted">💬 ملاحظة الأسطى: "@bid.Note"</small>
                            </div>
                        </div>
                        <a asp-controller="Customer" asp-action="RequestDashboard" asp-route-requestId="@bid.JobRequestId" class="btn btn-sm text-white" style="background-color: #ff6600; border-radius: 6px;">
                            معاينة الطلب 👀
                        </a>
                    </div>
                }
                else if (role == "CraftMan")
                {
                    <!-- إشعار خاص بالصنايعي فقط -->
                    <div class="p-3 d-flex justify-content-between align-items-center border-bottom bg-white shadow-sm" style="border-radius: 8px; border-right: 4px solid #28a745;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5">🎉</span>
                            <div>
                                <span class="fw-bold text-success">مبروك! تم قبول عرضك</span> من قبل العميل على شغلانة (<span class="text-secondary">@bid.JobRequest?.Category?.Name</span>).
                                <br />
                                <span class="small text-muted">تفاصيل الشغل: "@bid.JobRequest?.Description"</span>
                            </div>
                        </div>
                        <a asp-controller="Artisan" asp-action="AvailableJobs" class="btn btn-sm btn-success" style="border-radius: 6px;">
                            ابدأ الشغل 🚀
                        </a>
                    </div>
                }
            }
        </div>
    }
</div>