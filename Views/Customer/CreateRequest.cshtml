@model Ostawy.Models.JobRequest

@{
    ViewData["Title"] = "طلب صنايعي";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:760px; margin-top:120px; margin-bottom:60px;">

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <div class="text-center mb-5">

                <div class="mb-3" style="font-size:65px;">🛠️</div>

                <h2 class="fw-bold" style="color:#031636;">
                    اطلب صنايعي
                </h2>

                <p class="text-muted mb-0">
                    اكتب تفاصيل المشكلة، وسيتم إرسال طلبك إلى الصنايعية المناسبين حسب التخصص.
                </p>

            </div>

            <form asp-action="CreateRequest" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger">
                </div>

                <!-- Profession -->

                <div class="mb-4">

                    <label asp-for="ProfessionId" class="form-label fw-bold">

                        <i class="fa-solid fa-screwdriver-wrench me-1"></i>
                        التخصص المطلوب

                    </label>

                    <select asp-for="ProfessionId" asp-items="ViewBag.Professions" class="form-select form-select-lg">

                        <option value="">
                            -- اختر التخصص --
                        </option>

                    </select>

                    <span asp-validation-for="ProfessionId" class="text-danger small"></span>

                </div>

                <!-- Budget -->

                <div class="mb-4">

                    <label asp-for="EstimatedPrice" class="form-label fw-bold">

                        <i class="fa-solid fa-money-bill-wave me-1"></i>
                        الميزانية المتوقعة

                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            ج.م
                        </span>

                        <input asp-for="EstimatedPrice" type="number" min="1" class="form-control form-control-lg"
                               placeholder="مثال: 300" />

                    </div>

                    <small class="text-muted">
                        الميزانية تساعد الصنايعي في تقديم عرض مناسب.
                    </small>

                    <span asp-validation-for="EstimatedPrice" class="text-danger d-block"></span>

                </div>

                <!-- Description -->

                <div class="mb-4">

                    <label asp-for="Description" class="form-label fw-bold">

                        <i class="fa-solid fa-file-lines me-1"></i>
                        وصف المشكلة

                    </label>

                    <textarea asp-for="Description" rows="6" class="form-control"
                              placeholder="مثال: يوجد تسريب مياه أسفل الحوض بالمطبخ وأحتاج إلى تغيير المحبس وتركيب خرطوم جديد."></textarea>

                    <small class="text-muted">
                        كلما كان الوصف أوضح، كانت العروض أدق وأسرع.
                    </small>

                    <span asp-validation-for="Description" class="text-danger d-block"></span>

                </div>

                <div class="alert alert-light border rounded-3">

                    <strong>ماذا يحدث بعد نشر الطلب؟</strong>

                    <ul class="mb-0 mt-2">
                        <li>سيظهر الطلب للصنايعية المناسبين.</li>
                        <li>ستبدأ عروض الأسعار في الوصول إليك.</li>
                        <li>يمكنك مقارنة العروض واختيار الأنسب.</li>
                    </ul>

                </div>

                <button type="submit" class="btn w-100 text-white fw-bold py-3 mt-3"
                        style="background:#fd7613;border-radius:12px;font-size:18px;">

                    🚀 نشر الطلب

                </button>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}