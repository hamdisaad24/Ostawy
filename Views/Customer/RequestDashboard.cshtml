@model Ostawy.Models.JobRequest

@{
    ViewData["Title"] = "متابعة الطلب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top:120px;">
    <div class="row g-4">
        <!-- Request Details -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h4 class="fw-bold mb-4" style="color:#031636;">
                        تفاصيل الطلب
                    </h4>
                    <div class="mb-3">
                        <small class="text-muted">التخصص</small>
                        <h6 class="fw-bold mt-1">
                            @Model.Profession?.Name
                        </h6>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">الميزانية</small>
                        <h5 class="fw-bold text-success">
                            @Model.EstimatedPrice ج.م
                        </h5>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">
                            الحالة
                        </small>
                        <div class="mt-2">
                            @if (Model.Status == "Open")
                            {
                                <span class="badge bg-warning text-dark">
                                    ⏳ في انتظار العروض
                                </span>
                            }
                            else if (Model.Status == "Assigned")
                            {
                                <span class="badge bg-primary">
                                    👷 تم اختيار الصنايعي
                                </span>
                            }
                            else if (Model.Status == "Completed")
                            {
                                <span class="badge bg-success">
                                    ✅ تم الانتهاء
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    ❌ تم إلغاء الطلب
                                </span>
                            }
                        </div>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted">
                            الوصف
                        </small>
                        <p class="mt-2 mb-0" style="line-height:1.8">
                            @Model.Description
                        </p>
                    </div>
                    @if (Model.Status == "Open")
                    {
                        <button class="btn btn-outline-danger w-100" onclick="cancelRequest()">
                            إلغاء الطلب
                        </button>
                    }

                    @if (Model.Status == "Assigned")
                    {
                        <button class="btn w-100 text-white mt-2" style="background:#198754;" onclick="completeRequest()">
                            ✅ تأكيد انتهاء العمل
                        </button>
                    }
                </div>
            </div>
        </div>
        <!-- Bids -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold" style="color:#031636;">
                            عروض الصنايعية
                        </h4>
                        <span class="badge bg-warning text-dark" id="bidsCount">
                            0 عروض
                        </span>
                    </div>
                    <hr />
                    <div id="bidsContainer">
                        <div class="text-center py-5">
                            <div class="spinner-border text-warning"></div>
                            <p class="mt-3 text-muted">
                                جاري تحميل العروض...
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const requestId = '@Model.Id';
        loadBids();
        @if (Model.Status == "Open")
        {
                <text>
                        setInterval(loadBids,5000);
                </text>
        }
            function loadBids() {
                $.get("/Customer/GetBidsForRequest",
                    {
                        requestId: requestId
                    },
                    function (bids) {
                        $("#bidsCount").text(bids.length + " عروض");
                        if (bids.length === 0) {
                            @if (Model.Status == "Assigned")
                            {
                                    <text>
                                            $("#bidsContainer").html(`
                                            <div class="alert alert-primary text-center mb-0">
                                                    <h5 class="mb-2">👷 تم اختيار الصنايعي بنجاح</h5>
                                                    <p class="mb-0">
                                                            في انتظار انتهاء تنفيذ العمل.
                                                    </p>
                                            </div>
                                            `);

                                    </text>
                            }
                                else if (Model.Status == "Completed")
                                {
                                    <text>
                                            $("#bidsContainer").html(`
                                            <div class="alert alert-success text-center mb-0">
                                                    <h5 class="mb-2">✅ تم الانتهاء من الطلب</h5>
                                            </div>
                                            `);
                                    </text>
                            }
                                else
                                {
                                    <text>
                                            $("#bidsContainer").html(`
                                            <div class="text-center py-5">
                                                    <h5>لا توجد عروض حتى الآن</h5>
                                                    <p class="text-muted">
                                                            سيتم تحديث الصفحة تلقائياً عند وصول عروض جديدة.
                                                    </p>
                                            </div>
                                            `);
                                    </text>
                            }
                return;
                        }
                        let html = "";
                        bids.forEach(function (b) {
                            html += `
                <div class="card border mb-3 shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h5 class="fw-bold mb-1">

                                    ${b.artisanName}

                                    ${b.isVerified
                                    ? '<span class="badge bg-primary ms-2">PRO</span>'
                                    : ''
                                }

                                </h5>

                                <small class="text-muted">
                                    ${b.createdAt} 
                                    <br><strong> رقم الهاتف:  ${b.phoneNumber}</strong>
                                </small>

                            </div>

                            <div class="text-end">

                                <h4 class="text-success fw-bold">
                                    ${b.offerPrice} ج.م
                                </h4>

                            </div>

                        </div>

                        <hr>

                        <p class="mb-3">

                            ${b.note ?? "لا توجد ملاحظات."}

                        </p>
                `;

                            @if (Model.Status == "Open")
                            {
                                    <text>

                                            html+=`
                                            <div class="d-flex gap-2">

                                                    <button class="btn btn-success w-100"
                            onclick="acceptBid('${b.id}')">
                                                            قبول
                                                    </button>

                                                    <button class="btn btn-outline-danger w-100"
                            onclick="rejectBid('${b.id}')">
                                                            رفض
                                                    </button>

                                            </div>
                                            `;

                                    </text>
                            }

                                html+=`
                    </div>
                </div>
                `;

                        });

                        $("#bidsContainer").html(html);

                    });

            }

        function acceptBid(id) {

            if (!confirm("هل تريد قبول هذا العرض؟"))
                return;

            $.post("/Customer/ApiAcceptBid",
                {
                    bidId: id
                },
                function (res) {

                    alert(res.message);

                    if (res.success)
                        location.reload();

                });

        }

        function rejectBid(id) {

            if (!confirm("هل تريد رفض هذا العرض؟"))
                return;

            $.post("/Customer/ApiRejectBid",
                {
                    bidId: id
                },
                function (res) {

                    alert(res.message);

                    if (res.success)
                        loadBids();

                });

        }

        function cancelRequest() {

            if (!confirm("هل تريد إلغاء الطلب؟"))
                return;

            $.post("/Customer/CancelRequest",
                {
                    requestId: requestId
                },
                function (res) {

                    if (res.success) {

                        window.location = "/Customer/MyRequests";

                    }

                });

        }

        function completeRequest() {

            if (!confirm("هل تم الانتهاء من تنفيذ العمل؟"))
                return;

            $.post("/Customer/CompleteRequest",
                {
                    requestId: requestId
                },
                function (res) {

                    alert(res.message);

                    if (res.success) {

                        location.reload();

                    }

                });

        }

    </script>

}