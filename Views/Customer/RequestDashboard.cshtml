@model Ostawy.Models.JobRequest

@{
    ViewData["Title"] = "متابعة الطلب - أوستاوي";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top: 140px; margin-bottom: 60px;">
    <div class="row g-4">
        
        <div class="col-lg-5 text-right">
            <div class="card shadow-sm border-0 p-4" style="border-radius: 20px; background: #ffffff;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    @if (Model.Status == "Open")
                    {
                        <span class="badge bg-success px-3 py-2" style="border-radius: 8px;">🟢 الطلب مفتوح ويستقبل عروض</span>
                    }
                    else if (Model.Status == "Closed" || Model.Status == "Accepted")
                    {
                        <span class="badge bg-danger px-3 py-2" style="border-radius: 8px;">🔒 الطلب مغلق ومكتمل</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary px-3 py-2" style="border-radius: 8px;">@Model.Status</span>
                    }
                    <span class="text-muted small">📅 @Model.CreatedAt.ToString("yyyy-MM-dd")</span>
                </div>
                
                <h4 class="fw-bold mb-3" style="color: #031636;">تفاصيل طلبك</h4>
                <hr class="text-muted opacity-25">

                <div class="mb-3">
                    <h6 class="fw-bold text-muted small mb-1">التخصص المطلوب:</h6>
                    <p class="fw-bold fs-5" style="color: #fd7613;">⚙️ @Model.Category?.Name</p>
                </div>

                <div class="mb-3">
                    <h6 class="fw-bold text-muted small mb-1">الميزانية التقريبية:</h6>
                    <p class="fw-bold fs-5 text-dark">💰 @Model.EstimatedPrice ج.م</p>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold text-muted small mb-1">وصف المشكلة:</h6>
                    <p class="p-3 rounded-3 small" style="background-color: #f8fafc; color: #334155; line-height: 1.8;">
                        @Model.Description
                    </p>
                </div>

                @if (Model.Status == "Open")
                {
                    <button class="btn btn-outline-danger w-100 fw-bold py-2.5" style="border-radius: 10px;" onclick="cancelRequest(@Model.Id)">
                        🗑️ إلغاء هذا الطلب بالكامل
                    </button>
                }
            </div>
        </div>

        <div class="col-lg-7 text-right">
            <div class="card shadow-sm border-0 p-4 d-flex flex-column h-100" style="border-radius: 20px; background: #ffffff; min-height: 450px;">
                <h4 class="fw-bold mb-2" style="color: #031636;">عروض الأسعار الواصلة حالياً</h4>
                <p class="text-muted small mb-4">الصنايعية القريبين منك بيقدموا عروضهم دلوقتي.. تقدر تقبل العرض المناسب ليك.</p>
                
                <div id="liveBidsContainer" class="flex-grow-1 d-flex flex-column gap-3">
                    <div class="text-center text-muted my-auto">
                        <div class="spinner-border text-warning mb-3" role="status"></div>
                        <p class="m-0 small">جاري البحث عن فنيين واستقبال العروض لايف...</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        var requestId = @Model.Id;
        var isRequestClosed = '@Model.Status' === 'Closed' || '@Model.Status' === 'Accepted' || '@Model.Status' === 'Cancelled';

        function loadLiveBids() {
            if (isRequestClosed) {
                $('#liveBidsContainer').html(`
                    <div class="text-center text-muted my-auto">
                        <div class="fs-2 mb-2">🔒</div>
                        <h5 class="fw-bold">الطلب منتهي ومغلق</h5>
                        <p class="m-0 small">تم قبول عرض أحد الفنيين بنجاح أو تم إلغاء الطلب.</p>
                    </div>
                `);
                return;
            }

            $.ajax({
                url: '/Customer/GetBidsForRequest?requestId=' + requestId,
                type: 'GET',
                success: function(bids) {
                    var container = $('#liveBidsContainer');
                    if(bids && bids.length > 0) {
                        var html = '';
                        bids.forEach(function(bid) {
                            // 🚀 الفحص الذكي لشارة التوثيق لايف
                            var badgeHtml = bid.isVerified ? '<span class="badge bg-primary me-1 fw-bold" style="font-size: 11px; border-radius: 6px;">💙 موثق PRO</span>' : '';

                            html += `
                                <div id="bid-card-${bid.id}" class="p-4 border rounded-4 text-right position-relative card-bid animate__animated animate__fadeIn" style="border-color: #f1f5f9 !important; background-color: #f8fafc; transition: all 0.3s; box-shadow: 0 2px 8px rgba(0,0,0,0.01);">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fs-4">👷</span>
                                            <div>
                                                <h6 class="m-0 fw-bold text-dark">
                                                    ${bid.artisanName} ${badgeHtml}
                                                </h6>
                                                <small class="text-muted" style="font-size: 11px;">${bid.createdAt}</small>
                                            </div>
                                        </div>
                                        <span class="fw-black text-success fs-4">${bid.offerPrice} ج.م</span>
                                    </div>
                                    <p class="text-muted small mb-3 bg-white p-3 rounded-3 border border-light">${bid.note || 'لم يترك الفني أي ملاحظات إضافية.'}</p>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-dark w-50 fw-bold py-2" style="border-radius: 8px;" onclick="acceptBid(${bid.id})">✅ قبول العرض</button>
                                        <button class="btn btn-sm btn-outline-danger w-50 fw-bold py-2" style="border-radius: 8px;" onclick="rejectBid(${bid.id})">❌ رفض</button>
                                    </div>
                                </div>
                            `;
                        });
                        container.html(html);
                    } else {
                        container.html(`
                            <div class="text-center text-muted my-auto">
                                <div class="spinner-border spinner-border-sm text-warning mb-2" role="status"></div>
                                <p class="m-0 small">مستنيين أول عرض من الصنايعية...</p>
                            </div>
                        `);
                    }
                }
            });
        }

        // 🟢 قبول العرض
        function acceptBid(bidId) {
            if(confirm("هل أنت متأكد من قبول هذا العرض؟ سيتم غلق الشغلانة تلقائياً لباقي الفنيين.")) {
                $.ajax({
                    url: '/Customer/ApiAcceptBid',
                    type: 'POST',
                    data: { bidId: bidId },
                    success: function(response) {
                        if(response.success) {
                            alert(response.message);
                            isRequestClosed = true;
                            loadLiveBids();
                            window.location.reload();
                        } else {
                            alert("حدث خطأ: " + response.message);
                        }
                    }
                });
            }
        }

        // ❌ رفض العرض
        function rejectBid(bidId) {
            if(confirm("هل تريد رفض هذا العرض؟")) {
                $.ajax({
                    url: '/Customer/ApiRejectBid',
                    type: 'POST',
                    data: { bidId: bidId },
                    success: function(response) {
                        if(response.success) {
                            $(`#bid-card-${bidId}`).fadeOut(300, function() {
                                loadLiveBids();
                            });
                        } else {
                            alert("حدث خطأ أثناء الرفض");
                        }
                    }
                });
            }
        }

        // 🗑️ إلغاء الطلب بالكامل
        function cancelRequest(reqId) {
            if(confirm("هل أنت متأكد من إلغاء هذا الطلب وحذفه بالكامل؟")) {
                $.ajax({
                    url: '/Customer/CancelRequest',
                    type: 'POST',
                    data: { requestId: reqId },
                    success: function(response) {
                        if(response.success) {
                            alert("تم إلغاء طلبك بنجاح.");
                            window.location.href = '/Customer/MyRequests';
                        } else {
                            alert("حدث خطأ أثناء إلغاء الطلب");
                        }
                    }
                });
            }
        }

        $(document).ready(function() {
            loadLiveBids();
            if (!isRequestClosed) {
                setInterval(loadLiveBids, 4000);
            }
        });
    </script>
}