@model Ostawy.ViewModels.CraftManProfessionViewModel

@{
    ViewData["Title"] = "إضافة حرفة جديدة";
}

@section Styles{
<style>
    .page-container{
        margin-top:130px;
        margin-bottom:60px;
    }

    .card-ostawy{
        border:none;
        border-radius:20px;
        box-shadow:0 10px 30px rgba(0,0,0,.08);
        overflow:hidden;
    }

    .card-header-ostawy{
        background:#031636;
        color:white;
        padding:25px;
    }

    .card-header-ostawy h2{
        font-weight:800;
        margin:0;
    }

    .form-label{
        font-weight:700;
        color:#031636;
        margin-bottom:8px;
    }

    .form-control,
    .form-select{
        border-radius:12px;
        min-height:50px;
    }

    .form-control:focus,
    .form-select:focus{
        border-color:#fd7613;
        box-shadow:0 0 0 .2rem rgba(253,118,19,.2);
    }

    textarea{
        resize:none;
    }

    .btn-save{
        background:#fd7613;
        color:white;
        font-weight:700;
        border:none;
        border-radius:12px;
        padding:12px 35px;
        transition:.3s;
    }

    .btn-save:hover{
        background:#031636;
        color:white;
    }

    .btn-cancel{
        border:2px solid #031636;
        color:#031636;
        font-weight:700;
        border-radius:12px;
        padding:12px 35px;
    }

    .btn-cancel:hover{
        background:#031636;
        color:white;
    }

    .upload-box{
        border:2px dashed #fd7613;
        border-radius:15px;
        padding:25px;
        text-align:center;
        background:#fffaf6;
        transition:.3s;
    }

    .upload-box:hover{
        background:#fff3eb;
    }

    .preview-container{
        display:flex;
        flex-wrap:wrap;
        gap:15px;
        margin-top:20px;
    }

    .preview-container img{
        width:130px;
        height:130px;
        object-fit:cover;
        border-radius:15px;
        border:3px solid #031636;
    }

    .note{
        color:#666;
        font-size:14px;
    }
    .preview-item{
    position:relative;
}

.preview-item img{
    width:130px;
    height:130px;
    object-fit:cover;
    border-radius:15px;
    border:3px solid #031636;
}

.remove-image{
    position:absolute;
    top:-8px;
    left:-8px;
    width:28px;
    height:28px;
    border:none;
    border-radius:50%;
    background:#dc3545;
    color:#fff;
    cursor:pointer;
    font-weight:bold;
    box-shadow:0 4px 10px rgba(0,0,0,.25);
}

.remove-image:hover{
    background:#bb2d3b;
}
</style>
}

<div class="container page-container">

    <div class="card card-ostawy">

        <div class="card-header-ostawy">

            <h2>إضافة حرفة جديدة</h2>

            <small>أضف بيانات الحرفة وأرفق بعض صور أعمالك.</small>

        </div>

        <div class="card-body p-5">

            <form asp-action="BecomeCraftsman"
                  method="post"
                  enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-4">
                </div>

                <div class="mb-4">

                    <label asp-for="ProfessionId" class="form-label">
                        اختر الحرفة
                    </label>

                    <select asp-for="ProfessionId"
                            asp-items="ViewBag.Professions"
                            class="form-select">

                        <option value="">
                            -- اختر الحرفة --
                        </option>

                    </select>

                    <span asp-validation-for="ProfessionId"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="YearsOfExperience"
                           class="form-label">
                        سنوات الخبرة
                    </label>

                    <input asp-for="YearsOfExperience"
                           class="form-control"
                           min="0"
                           max="50"/>

                    <span asp-validation-for="YearsOfExperience"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="Bio"
                           class="form-label">
                        نبذة عن خبرتك
                    </label>

                    <textarea asp-for="Bio"
                              rows="6"
                              class="form-control"
                              placeholder="اكتب نبذة عن خبرتك والخدمات التي تقدمها...">
                    </textarea>

                    <span asp-validation-for="Bio"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                <label class="form-label">
                    صور أعمالك
                </label>

                <div class="upload-box">

                    <i class="fa-solid fa-images"
                    style="font-size:45px;color:#fd7613"></i>

                    <h5 class="mt-3">
                        أضف حتى 5 صور
                    </h5>

                    <p class="note">
                        JPG - PNG - WEBP
                    </p>

                    <input type="file"
                        id="imagePicker"
                        accept="image/*"
                        class="form-control mt-3" />

                </div>

                <span asp-validation-for="Images" class="text-danger"></span>

                <div id="preview" class="preview-container mt-4"></div>

            </div>

                <div class="d-flex justify-content-end gap-3">

                    <a asp-action="Index"
                       class="btn btn-cancel">

                        رجوع

                    </a>

                    <button class="btn btn-save">

                        حفظ الحرفة

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts{

    <partial name="_ValidationScriptsPartial"/>

    <script>

        const picker = document.getElementById("imagePicker");
const preview = document.getElementById("preview");
const form = document.querySelector("form");

let selectedFiles = [];

picker.addEventListener("change", function () {

    if (this.files.length === 0)
        return;

    if (selectedFiles.length >= 5) {
        alert("الحد الأقصى 5 صور.");
        this.value = "";
        return;
    }

    const file = this.files[0];

    if (selectedFiles.length == 5) {
        alert("يمكنك رفع 5 صور فقط.");
        this.value = "";
        return;
    }

    selectedFiles.push(file);

    renderImages();

    this.value = "";
});

function renderImages() {

    preview.innerHTML = "";

    selectedFiles.forEach((file, index) => {

        const reader = new FileReader();

        reader.onload = function (e) {

            const item = document.createElement("div");
            item.className = "preview-item";

            item.innerHTML = `
                <img src="${e.target.result}">
                <button type="button"
                        class="remove-image"
                        data-index="${index}">
                    ×
                </button>
            `;

            preview.appendChild(item);

        };

        reader.readAsDataURL(file);

    });

}

preview.addEventListener("click", function (e) {

    if (!e.target.classList.contains("remove-image"))
        return;

    const index = parseInt(e.target.dataset.index);

    selectedFiles.splice(index, 1);

    renderImages();

});

form.addEventListener("submit", function () {

    const dataTransfer = new DataTransfer();

    selectedFiles.forEach(file => {
        dataTransfer.items.add(file);
    });

    const hiddenInput = document.createElement("input");
    hiddenInput.type = "file";
    hiddenInput.name = "Images";
    hiddenInput.multiple = true;
    hiddenInput.files = dataTransfer.files;

    form.appendChild(hiddenInput);

});

    </script>

}