@model Ostawy.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="container py-5" style="margin-top:120px;">

    <div class="row g-4">

        <!-- معلومات المستخدم -->
        <div class="col-lg-4">

            <div class="card border-0 shadow rounded-4">

                <div class="card-body text-center p-5">

                    <div class="mx-auto mb-4 d-flex justify-content-center align-items-center rounded-circle"
                         style="width:110px;height:110px;background:#031636;color:white;font-size:45px;">

                        @Model.FullName[0]

                    </div>

                    <h3 class="fw-bold" style="color:#031636">
                        @Model.FullName
                    </h3>

                    <p class="text-muted mb-1">
                        @Model.Email
                    </p>

                    <p class="text-muted">
                        @Model.PhoneNumber
                    </p>

                    <hr>

                    <div class="text-end">

                        <p>
                            <strong>العنوان</strong>
                        </p>

                        <p class="text-muted">
                            @Model.Address
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-8">

            @if (Model.IsCraftsman)
            {
                <div class="card border-0 shadow rounded-4">

                    <div class="card-header border-0 text-white py-3"
                        style="background:#031636;">

                        <div class="d-flex justify-content-between align-items-center">

                            <h4 class="mb-0 fw-bold">
                                بيانات الحرفي
                            </h4>

                            <form asp-controller="Profile"
                                asp-action="ToggleAvailability"
                                method="post">

                                <button type="submit"
                                        class="btn @(Model.IsAvailable ? "btn-success" : "btn-danger") fw-bold">

                                    @(Model.IsAvailable
                                        ? "🟢 متاح للعمل"
                                        : "🔴 غير متاح")

                                </button>

                            </form>

                        </div>

                    </div>

                    <div class="card-body p-4">

                        <div class="row mb-4">

                            <div class="col-md-6">

                                <div class="border rounded-4 p-4 text-center h-100">

                                    <h6 class="text-muted">
                                        عدد الحرف
                                    </h6>

                                    <h2 class="fw-bold"
                                        style="color:#fd7613">

                                        @Model.CurrentProfessions.Count

                                    </h2>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="border rounded-4 p-4 text-center h-100">

                                    <h6 class="text-muted">
                                        الحالة الحالية
                                    </h6>

                                    <h5 class="fw-bold">

                                        @if (Model.IsAvailable)
                                        {
                                            <span class="text-success">
                                                متاح لاستقبال الطلبات
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">
                                                غير متاح حالياً
                                            </span>
                                        }

                                    </h5>

                                </div>

                            </div>

                        </div>

                        <hr />

                        <h4 class="fw-bold mb-4"
                            style="color:#031636">

                            الحرف المسجلة

                        </h4>

                        <div class="row">

                            @foreach (var profession in Model.CurrentProfessions)
                            {
                                <div class="card shadow-sm mb-4 rounded-4">

                                    <div class="card-body">

                                        <h4 class="fw-bold text-primary">
                                            @profession.Profession
                                        </h4>

                                        <p>
                                            <strong>سنوات الخبرة:</strong>
                                            @profession.YearsOfExperience
                                        </p>

                                        <p>@profession.Bio</p>

                                        <div class="row g-3">

                                            @foreach (var image in profession.Images)
                                            {
                                                <div class="col-md-3">

                                                    <img src="@image"
                                                        class="img-fluid rounded shadow-sm"
                                                        style="height:180px;width:100%;object-fit:cover;" />

                                                </div>
                                            }

                                        </div>

                                    </div>

                                </div>
                            }

                        </div>

                        <div class="text-center mt-4">

                            <a asp-controller="Profile"
                            asp-action="BecomeCraftsman"
                            class="btn text-white fw-bold px-4 py-2"
                            style="background:#fd7613;">

                                + إضافة حرفة جديدة

                            </a>

                        </div>

                    </div>

                </div>
            }
            else
            {

                <div class="card border-0 shadow rounded-4">

                    <div class="card-body text-center py-5">

                        <h3 style="color:#031636">

                            أنت عميل

                        </h3>

                        <p class="text-muted">

                            يمكنك التسجيل كحرفي لإضافة خدماتك.

                        </p>

                        <a asp-action="BecomeCraftsman"
                           class="btn text-white px-4"
                           style="background:#fd7613">

                            سجل كحرفي

                        </a>

                    </div>

                </div>

            }

        </div>

    </div>

</div>