@model Ostawy.ViewModels.ProfessionViewModel

@{
    ViewData["Title"] = "حذف الحرفة";
}

<style>
    :root {
        --primary: #031636;
        --secondary: #fd7613;
        --danger: #dc3545;
    }

    .page-container {
        max-width: 700px;
        margin: 120px auto 60px;
        padding: 0 20px;
    }

    .card-box {
        background: #fff;
        border-radius: 18px;
        padding: 35px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .page-title {
        color: var(--danger);
        font-weight: 900;
        text-align: center;
        margin-bottom: 25px;
    }

    .warning-box {
        background: #fff5f5;
        border: 1px solid #f5c2c7;
        border-radius: 12px;
        padding: 18px;
        margin-bottom: 25px;
        text-align: center;
    }

    .warning-box h4 {
        color: var(--danger);
        font-weight: bold;
        margin-bottom: 10px;
    }

    .warning-box p {
        margin: 0;
        color: #555;
    }

    .info-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .info-row:last-child {
        margin-bottom: 0;
    }

    .info-title {
        color: var(--primary);
        font-weight: bold;
    }

    .info-value {
        font-weight: 600;
        color: #444;
    }

    .btn-delete {
        background: var(--danger);
        color: #fff;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: bold;
        transition: .3s;
    }

    .btn-delete:hover {
        background: #bb2d3b;
        color: white;
    }

    .btn-back {
        background: var(--primary);
        color: #fff;
        text-decoration: none;
        padding: 12px 28px;
        border-radius: 10px;
        margin-right: 10px;
        transition: .3s;
    }

    .btn-back:hover {
        background: var(--secondary);
        color: white;
        text-decoration: none;
    }
</style>

<div class="page-container">

    <div class="card-box">

        <h2 class="page-title">
            حذف الحرفة
        </h2>

        <div class="warning-box">
            <h4>⚠️ تأكيد الحذف</h4>
            <p>
                هل أنت متأكد أنك تريد حذف هذه الحرفة؟
                لا يمكن التراجع عن هذه العملية.
            </p>
        </div>

        <div class="info-box">

            <div class="info-row">
                <span class="info-title">اسم الحرفة</span>
                <span class="info-value">@Model.Name</span>
            </div>

        </div>

        <form asp-action="Delete" method="post">

            <input asp-for="Id" type="hidden" />

            <div class="d-flex justify-content-center">

                <button type="submit" class="btn-delete">
                    🗑️ حذف الحرفة
                </button>

                <a asp-action="Index" class="btn-back">
                    رجوع
                </a>

            </div>

        </form>

    </div>

</div>