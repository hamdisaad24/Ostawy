                        <a asp-controller="Account" asp-action="Profile" class="nav-item">أعمالي</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الطلبات</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الإحصائيات</a>
                    }
