            border-bottom: 1px solid #f1f5f9;
        }
        .offcanvas-title {
            font-weight: 900;
            color: #031636;
        }
        .mobile-nav-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            padding: 20px 0;
        }
        .mobile-nav-item {
            color: #031636;
            font-weight: 700;
            font-size: 16px;
            text-decoration: none;
            padding: 10px 15px;
            border-radius: 8px;
            transition: all 0.2s;
        }
        .mobile-nav-item:hover {
            background-color: #fff4e6;
            color: #fd7613;
            text-decoration: none;
        }

        @@media (max-width: 992px) {
            .main-nav { display: none; }
            .menu-toggle-btn { display: block; }
            .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 30px; }
        }
        @@media (max-width: 768px) {
            .footer-grid { grid-template-columns: 1fr; }
            .auth-nav { display: none; }
            .footer-bottom-flex { flex-direction: column; text-align: center; gap: 10px; }
        }
        @@media (max-width: 576px) {
            .footer-brand { justify-content: center; }
            .footer-title::after { right: 50%; transform: translateX(50%); }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject Ostawy.Data.ApplicationDbContext _context

@{
    bool isProUser = false;
    if (User!.Identity!.IsAuthenticated && User.IsInRole("CraftMan"))
    {
        var userIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (Guid.TryParse(userIdString, out Guid userId))
        {
            isProUser = _context.UserSubscriptions
                .Any(s => s.UserId == userId && s.IsActive && s.Plan!.Name == "Pro");
        }
    }
}

    <header class="main-header">
        <div class="custom-container header-container">
            <div class="d-flex align-items-center gap-3">
                <button class="menu-toggle-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
                    ☰
                </button>
                <a class="brand-box" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/osta.png" alt="لوجو أوستاوي" class="app-logo" asp-append-version="true">
                    <span class="app-name">أوستاوي</span>
                </a>
            </div>
            
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index" class="nav-item">الرئيسية</a>
                
                @if (User!.Identity!.IsAuthenticated)
                {
                    @if (User.IsInRole("CraftMan"))
                    {
                        <a asp-controller="Artisan" asp-action="AvailableJobs" class="nav-item">الطلبات المتاحة</a>
                        <a asp-controller="Artisan" asp-action="Notifications" class="nav-item">🔔 الإشعارات</a>
                        <a asp-controller="Artisan" asp-action="MyWorks" class="nav-item">أعمالي</a>
                                                    
                        <form asp-controller="Subscription" asp-action="Upgrade" method="get" class="d-inline ms-2">
                            <button type="submit" class="btn-upgrade-pro">🚀 ترقية إلى PRO</button>
                        </form>
                    }
                    else if (User.IsInRole("Client"))
                    {
                        <a href="#services" class="nav-item">الخدمات</a>
                        <a asp-controller="Customer" asp-action="MyRequests" class="nav-item">طلباتي</a>
                        <a asp-controller="Customer" asp-action="Notifications" class="nav-item">الإشعارات</a>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">العملاء</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الصنايعية</a>
                        <a asp-controller="Profession" asp-action="Index" class="nav-item">الحرف</a>
                        <a asp-controller="Admin" asp-action="Requests" class="nav-item">الطلبات</a>
                        <a asp-controller="Plan" asp-action="Index" class="nav-item">الباقات</a>
                    }
                }
                else
                {
                    <a href="#services" class="nav-item">الخدمات</a>
                    <a href="#how-it-works" class="nav-item">كيف يعمل؟</a>
                    <a href="#features" class="nav-item">المميزات</a>
                    <a href="#faq" class="nav-item">الأسئلة الشائعة</a>
                }
            </nav>
            
            <nav class="auth-nav">
                @if (User!.Identity!.IsAuthenticated)
                {
                    <a class="link-login" asp-area="" asp-controller="Profile" asp-action="index">بروفايل</a>
                    <a class="btn-register-nav" asp-area="" asp-controller="Account" asp-action="Logout">خروج</a>
                }
                else
                {
                    <a class="link-login" asp-area="" asp-controller="Account" asp-action="Login">تسجيل دخول</a>
                    <a class="btn-register-nav" asp-area="" asp-controller="Account" asp-action="Register">إنشاء حساب</a>
                }
            </nav>
        </div>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="mobileSidebarLabel">قائمة أوستاوي</h5>
            <button type="button" class="btn-close text-reset" data-bs-shadow="none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <nav class="mobile-nav-list">
                <a asp-controller="Home" asp-action="Index" class="mobile-nav-item">الرئيسية</a>
                @if (User!.Identity!.IsAuthenticated)
                {
                    @if (User.IsInRole("Client"))
                    {
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">الخدمات</a>
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">طلباتي</a>
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">الإشعارات</a>
                    }
                    else if(User.IsInRole("CraftMan"))
                    {
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">أعمالي</a>
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">الطلبات</a>
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">الإحصائيات</a>
                        
                        @if (!isProUser)
                        {
                            <div class="px-3 py-2">
                                <form asp-controller="Subscription" asp-action="UpgradeToPro" method="post">
                                    <input type="hidden" name="planId" value="5e45d947-c2d6-4f7d-90b6-83c485082a03" />
                                    <button type="submit" class="btn-upgrade-pro w-100 text-center py-2">🚀 ترقية إلى PRO</button>
                                </form>
                            </div>
                        }
                    }
                    else if(User.IsInRole("Admin"))
                    {
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">العملاء</a>
                        <a asp-controller="Account" asp-action="Profile" class="mobile-nav-item">الصنايعية</a>
                        <a asp-controller="Profession" asp-action="Index" class="mobile-nav-item">الحرف</a>
                        <a asp-controller="Admin" asp-action="Requests" class="mobile-nav-item">الطلبات</a>
                        <a asp-controller="Plan" asp-action="Index" class="nav-item">الباقات</a>
                    }
                    <hr>
                    <a class="mobile-nav-item text-primary" asp-controller="Profile" asp-action="Index">بروفايل</a>
                    <a class="mobile-nav-item text-danger" asp-controller="Account" asp-action="Logout">تسجيل الخروج</a>
                }
                else
                {
                    <a href="#services" class="mobile-nav-item" data-bs-dismiss="offcanvas">الخدمات</a>
                    <a href="#how-it-works" class="mobile-nav-item" data-bs-dismiss="offcanvas">كيف يعمل؟</a>
                    <a href="#features" class="mobile-nav-item" data-bs-dismiss="offcanvas">المميزات</a>
                    <a href="#faq" class="mobile-nav-item" data-bs-dismiss="offcanvas">الأسئلة الشائعة</a>
                    <hr>
                    <a class="mobile-nav-item text-primary" asp-controller="Account" asp-action="Login">تسجيل دخول</a>
                    <a class="mobile-nav-item text-success" asp-controller="Account" asp-action="Register">إنشاء حساب</a>
                }
            </nav>
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="custom-container footer-grid">
            <div class="footer-col brand-col">
                <div class="footer-brand">
                    <img src="~/images/osta.png" alt="لوجو أوستاوي" class="footer-logo" asp-append-version="true">
                    <span class="footer-app-name">أوستاوي</span>
                </div>
                <p class="footer-brand-desc">المنصة الأقوى والأسرع في مصر للربط بين أصحاب المنازل وأقرب الفنيين والصنايعية المعتمدين جغرافياً بكل أمان وشفافية.</p>
            </div>
            <div class="footer-col">
                <h4 class="footer-title">تصفح المنصة</h4>
                <ul class="footer-links-list">
                    <li><a href="/Home/MapView">اطلب أوستا على الخريطة</a></li>
                    <li><a href="#how-it-works">دليل الاستخدام السريع</a></li>
                    <li><a href="#faq">الأسئلة الشائعة</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 class="footer-title">أبرز التخصصات</h4>
                <ul class="footer-links-list">
                    <li><a href="#services">أعمال السباكة والصرف</a></li>
                    <li><a href="#services">كهرباء وتأسيس منازل</a></li>
                    <li><a href="#services">تكييف وتبريد الهواء</a></li>
                    <li><a href="#services">نقاشة ودهانات عصرية</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 class="footer-title">الدعم والمساعدة</h4>
                <ul class="footer-links-list">
                    <li><span class="footer-info-item">📞 رقم الدعم: 19999</span></li>
                    <li><span class="footer-info-item">✉ البريد: support@ostawy.com</span></li>
                    <li><a href="#">سياسة الخصوصية</a></li>
                    <li><a href="#">شروط الاستخدام</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="custom-container footer-bottom-flex">
                <p class="footer-copy">© 2026 أوستاوي. جميع الحقوق محفوظة لـ تيم مشروع التخرج.</p>
                <div class="footer-socials">
                    <a href="#" class="social-icon">Facebook</a>
                    <a href="#" class="social-icon">WhatsApp</a>
                    <a href="#" class="social-icon">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // بنجيب مسار الصفحة الحالية من الـ URL (مثال: /Profile أو /Artisan/AvailableJobs)
            var currentPath = window.location.pathname.toLowerCase();

            // 1. فحص روابط الـ Navbar الكبيرة
            $(".main-nav a, .auth-nav a").each(function () {
                var linkHref = $(this).attr("href");
                if (linkHref) {
                    linkHref = linkHref.toLowerCase();
                    // لو اللينك مش الصفحة الرئيسية وفيه جزء مطابق للمسار الحالي، أو لو متطابق تماماً
                    if ((linkHref !== "/" && linkHref !== "/home" && currentPath.indexOf(linkHref) !== -1) || (currentPath === linkHref)) {
                        $(this).addClass("active");
                    }
                }
            });

            // حالة خاصة للصفحة الرئيسية لو المسار فاضي أو /
            if (currentPath === "/" || currentPath === "/home" || currentPath === "/home/index") {
                $(".main-nav a[href*='Home']").addClass("active");
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>