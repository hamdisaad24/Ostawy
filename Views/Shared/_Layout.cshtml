                    {
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">العملاء</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الصنايعية</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الحرف</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الطلبات</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">التقارير</a>
                        <a asp-controller="Account" asp-action="Profile" class="nav-item">الشكاوى</a>
                    }
                }
                else
                {
                    <a href="#services" class="nav-item">الخدمات</a>
                    <a href="#how-it-works" class="nav-item">كيف يعمل؟</a>
                    <a href="#features" class="nav-item">المميزات</a>
                    <a href="#faq" class="nav-item">الأسئلة الشائعة</a>
                }
            </nav>
            
            <nav class="auth-nav">
                @if (User!.Identity!.IsAuthenticated)
                {
                    <a class="link-login" asp-area="" asp-controller="Profile" asp-action="Index">بروفايل</a>
                    <a class="btn-register-nav" asp-area="" asp-controller="Account" asp-action="Logout">خروج</a>
                }
                else
