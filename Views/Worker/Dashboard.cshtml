@model Ostawy.Models.User

@{
    ViewData["Title"] = "أوستاوي - لوحة تحكم الأسطى";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>أوستاوي - لوحة تحكم العامل</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Noto Sans Arabic', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen antialiased">

    <header class="sticky top-0 z-50 flex justify-between items-center w-full px-4 md:px-12 h-16 bg-white/90 backdrop-blur-md text-slate-900 shadow-sm border-b border-slate-200">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-orange-500 text-3xl">engineering</span>
            <div class="text-2xl font-black tracking-tighter text-slate-900">أوستاوي</div>
        </div>
        <div class="hidden md:flex gap-8 items-center">
            <nav class="flex gap-2">
                <a class="text-sm font-bold bg-slate-100 text-orange-600 px-4 py-2 rounded-xl transition-all" href="/Worker/Dashboard">لوحة التحكم</a>
                <a class="text-sm font-semibold text-slate-600 hover:text-slate-900 px-4 py-2 rounded-xl transition-colors" href="/Home/WorkerMap">خريطة المزادات 🗺️</a>
                <a class="text-sm font-semibold text-slate-600 hover:text-slate-900 px-4 py-2 rounded-xl transition-colors" href="/Worker/CompleteProfile">تعديل ملفي 👤</a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <div class="text-left hidden sm:block">
                <span class="text-xs text-slate-400 block">مرحباً بك</span>
                <span class="text-sm font-black text-slate-800">الأسطى/ @ViewBag.WorkerName</span>
            </div>
            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-orange-500 to-amber-400 p-0.5 shadow-md shadow-orange-500/10 flex items-center justify-center text-white font-black">
                ⚒️
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 md:px-12 py-8 pb-24 md:pb-8 space-y-6">

        @if (ViewBag.IsProfileIncomplete == true)
        {
            <div class="bg-gradient-to-r from-red-50 to-transparent border-2 border-red-200 rounded-2xl p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shadow-sm relative overflow-hidden">
                <div class="flex items-start gap-4 z-10">
                    <div class="p-3 bg-red-100 text-red-600 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-2xl animate-bounce">warning</span>
                    </div>
                    <div>
                        <h3 class="font-black text-red-800 text-lg">حسابك غير نشط على الخريطة حالياً!</h3>
                        <p class="text-sm text-slate-600 mt-1 max-w-2xl leading-relaxed">عشان تظهر للزبائن في مصر وتبدأ تستقبل طلبات وتبعت عروض أسعار تنافسية، لازم تكمل تخصصك وسعرك وتلقط الـ GPS بتاعك أولاً.</p>
                    </div>
                </div>
                <a href="/Worker/CompleteProfile" class="w-full md:w-auto px-6 py-3.5 bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white font-black text-sm rounded-xl transition-all shadow-md text-center z-10 whitespace-nowrap">
                    إكمال البيانات وتنشيط الحساب 🚀
                </a>
            </div>
        }

        <section class="@(ViewBag.IsProfileIncomplete == true ? "opacity-30 pointer-events-none select-none" : "")">
            <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h2 class="text-lg font-black text-slate-900 flex items-center gap-2">
                        <span id="statusDot" class="w-2 h-2 rounded-full @(ViewBag.IsAvailable ? "bg-emerald-500 animate-ping" : "bg-red-500")"></span>
                        حالة الاستعداد لتلقي طلبات الزبائن
                    </h2>
                    <p class="text-xs text-slate-500 mt-1">بمجرد اختيارك "متصل الآن"، سيظهر دبوسك للعملاء على الخريطة فوراً.</p>
                </div>
                <div class="flex p-1 bg-slate-50 border border-slate-200 rounded-xl w-full md:w-auto">
                    <button id="btnOnline" onclick="updateStatus(true)" class="flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all @(ViewBag.IsAvailable ? "bg-gradient-to-r from-orange-500 to-amber-500 text-white shadow-md" : "text-slate-400 hover:text-slate-600")">متصل الآن</button>
                    <button id="btnOffline" onclick="updateStatus(false)" class="flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all @(!ViewBag.IsAvailable ? "bg-gradient-to-r from-red-500 to-rose-600 text-white shadow-md" : "text-slate-400 hover:text-slate-600")">غير متصل</button>
                </div>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 @(ViewBag.IsProfileIncomplete == true ? "opacity-30 pointer-events-none select-none" : "")">
            
            <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm relative overflow-hidden flex flex-col justify-between group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="space-y-1">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">المناقصات المعلقة</p>
                            <h3 class="text-4xl font-black text-slate-900 mt-1">@ViewBag.ActiveBidsCount <span class="text-sm font-medium text-slate-400">عروض</span></h3>
                        </div>
                        <div class="w-12 h-12 bg-orange-50 text-orange-500 border border-orange-100 rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined">gavel</span>
                        </div>
                    </div>
                    <p class="text-xs text-slate-500 flex items-center gap-1 border-t border-slate-100 pt-3">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                        في انتظار موافقة الزبائن في رادار المزاد
                    </p>
                </div>

                <div class="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm flex flex-col justify-between group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="space-y-1">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">العقود المقبولة الحالية</p>
                            <h3 class="text-4xl font-black text-emerald-600 mt-1">@ViewBag.AcceptedJobsCount <span class="text-sm font-medium text-slate-400">طلبات</span></h3>
                        </div>
                        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 border border-emerald-100 rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined">handyman</span>
                        </div>
                    </div>
                    <div class="space-y-2 border-t border-slate-100 pt-3">
                        <div class="h-1.5 w-full bg-slate-100 rounded-full overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-emerald-500 to-teal-400" style="width: 100%;"></div>
                        </div>
                        <p class="text-[11px] text-slate-400">تم جلب البيانات حية من جدول العمليات</p>
                    </div>
                </div>

                <div class="sm:col-span-2 bg-white border border-slate-200 rounded-2xl shadow-sm p-6 relative flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="space-y-1 text-center md:text-right">
                        <h3 class="font-black text-slate-900 text-base">بوابة رادار الطلبات لايف 📡</h3>
                        <p class="text-xs text-slate-500 max-w-md">افتح الرادار لمشاهدة دبابيس طلبات ومشاكل العملاء القريبين منك في مصر، ادخل المزاد واعرض سعرك التنافسي فوراً.</p>
                    </div>
                    <a href="/Home/WorkerMap" class="w-full md:w-auto px-6 py-3 bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white font-bold text-xs rounded-xl shadow-md text-center transition-all whitespace-nowrap">
                        دخول رادار المناقصات 🗺️
                    </a>
                </div>
            </div>

            <div class="md:col-span-4 space-y-6">
                <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6">
                    <h3 class="font-black text-slate-800 text-sm mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-slate-400 text-sm">analytics</span>
                        مؤشرات الأداء والجودة
                    </h3>
                    <div class="flex items-end gap-3 mb-6">
                        <span class="text-4xl font-black text-slate-900 tracking-tight">@ViewBag.WorkerRating.ToString("0.0")</span>
                        <div class="pb-1">
                            <div class="flex text-amber-500 gap-0.5">
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star_half</span>
                            </div>
                            <p class="text-[11px] text-slate-400 mt-1">بناءً على @ViewBag.WorkerReviews تقييم حقيقي بالسيستم</p>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div class="space-y-1.5">
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-slate-500">معدل إكمال المزاد والمهام</span>
                                <span class="font-bold text-slate-800">98%</span>
                            </div>
                            <div class="h-1.5 w-full bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full bg-gradient-to-r from-orange-500 to-amber-400" style="width: 98%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function updateStatus(isOnline) {
            const formData = new FormData();
            formData.append('available', isOnline);

            try {
                const response = await fetch('/Worker/ToggleAvailability', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    // تحديث شكل الأزرار لايف بدون ريفريش للصفحة
                    const btnOnline = document.getElementById('btnOnline');
                    const btnOffline = document.getElementById('btnOffline');
                    const dot = document.getElementById('statusDot');

                    if (isOnline) {
                        btnOnline.className = "flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all bg-gradient-to-r from-orange-500 to-amber-500 text-white shadow-md";
                        btnOffline.className = "flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all text-slate-400 hover:text-slate-600";
                        dot.className = "w-2 h-2 rounded-full bg-emerald-500 animate-ping";
                    } else {
                        btnOnline.className = "flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all text-slate-400 hover:text-slate-600";
                        btnOffline.className = "flex-1 px-6 py-2.5 rounded-lg font-bold text-xs transition-all bg-gradient-to-r from-red-500 to-rose-600 text-white shadow-md";
                        dot.className = "w-2 h-2 rounded-full bg-red-500";
                    }
                }
            } catch (err) {
                console.error("خطأ أثناء تحديث الحالة:", err);
            }
        }
    </script>
</body>
</html>