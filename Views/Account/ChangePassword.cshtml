@model Ostawy.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تغيير كلمة المرور</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
        font-family: 'Noto Sans Arabic', sans-serif;
        background-color: #f8f9ff;
        }

        .hero-bg {
        background-image: linear-gradient(rgba(3,22,54,0.85), rgba(3,22,54,0.7)), url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800');
        background-size: cover;
        background-position: center;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col">

    <div class="flex-grow grid grid-cols-1 md:grid-cols-2">

        <!-- FORM SIDE -->
        <div class="flex items-center justify-center bg-white p-6">

            <div class="w-full max-w-md">

                <h2 class="text-3xl font-black mb-2">تغيير كلمة المرور</h2>
                <p class="text-gray-500 mb-6">قم بتحديث كلمة المرور الخاصة بك</p>

                <div asp-validation-summary="All" class="text-red-600 mb-4 text-sm font-bold"></div>

                <form asp-action="ChangePassword" method="post" class="space-y-4">

                    <input type="hidden" asp-for="Email" />

                    <!-- CURRENT PASSWORD -->
                    <div>
                        <label class="text-sm font-bold">كلمة المرور الحالية</label>

                        <div class="relative mt-2">
                            <input asp-for="CurrentPassword"
                                   id="currentPass"
                                   type="password"
                                   class="w-full p-3 border rounded-xl bg-gray-50 pr-12"
                                   placeholder="••••••••" />

                            <button type="button"
                                    onclick="togglePassword('currentPass','i1')"
                                    class="absolute left-3 top-1/2 -translate-y-1/2">
                                👁
                            </button>
                        </div>
                    </div>

                    <!-- NEW PASSWORD -->
                    <div>
                        <label class="text-sm font-bold">كلمة المرور الجديدة</label>

                        <div class="relative mt-2">
                            <input asp-for="NewPassword"
                                   id="newPass"
                                   type="password"
                                   class="w-full p-3 border rounded-xl bg-gray-50 pr-12"
                                   placeholder="••••••••" />

                            <button type="button"
                                    onclick="togglePassword('newPass')"
                                    class="absolute left-3 top-1/2 -translate-y-1/2">
                                👁
                            </button>
                        </div>
                    </div>

                    <!-- CONFIRM -->
                    <div>
                        <label class="text-sm font-bold">تأكيد كلمة المرور</label>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="w-full p-3 border rounded-xl bg-gray-50"
                               placeholder="••••••••" />
                    </div>

                    <button type="submit"
                            class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold hover:opacity-90">
                        حفظ التغيير
                    </button>

                </form>

            </div>

        </div>

        <!-- IMAGE SIDE -->
        <div class="hidden md:flex hero-bg items-center justify-center text-white p-10">

            <div>
                <h1 class="text-3xl font-black mb-4">أوستاوي</h1>
                <p class="text-white/80">
                    حافظ على أمان حسابك بتغيير كلمة المرور بشكل دوري
                </p>
            </div>

        </div>

    </div>

    <script>
        function togglePassword(id) {
        const input = document.getElementById(id);
        input.type = input.type === "password" ? "text" : "password";
        }
    </script>

</body>
</html>