@model Ostawy.ViewModels.ChangePasswordViewModel

@{
    Layout = null;
    ViewData["Title"] = "تغيير كلمة المرور";
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تغيير كلمة المرور</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;700;800&display=swap" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400" rel="stylesheet" />

    <style>
        body {
        font-family: 'Noto Sans Arabic', sans-serif;
        background-color: #f8f9ff;
        }

        .hero-bg {
        background-image: linear-gradient(rgba(3,22,54,0.85), rgba(3,22,54,0.7)), url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800');
        background-size: cover;
        background-position: center;
        }

        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col m-0 p-0">

    <div class="flex-grow grid grid-cols-1 md:grid-cols-2">

        <!-- LEFT FORM -->
        <div class="flex items-center justify-center bg-white p-6">

            <div class="w-full max-w-md">

                <h2 class="text-3xl font-black mb-2">
                    تغيير كلمة المرور
                </h2>

                <p class="text-gray-500 mb-6">
                    قم بتحديث كلمة المرور الخاصة بحسابك للحفاظ على أمان بياناتك
                </p>

                <div asp-validation-summary="All"
                     class="text-red-600 mb-4 text-sm font-bold">
                </div>

                <form asp-action="ChangePassword"
                      method="post"
                      class="space-y-4">

                    <!-- CURRENT PASSWORD -->
                    <div>
                        <label class="text-sm font-bold">
                            كلمة المرور الحالية
                        </label>

                        <div class="relative mt-2">

                            <input asp-for="CurrentPassword"
                                   id="currentPass"
                                   type="password"
                                   class="w-full p-3 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-orange-300 pr-12"
                                   placeholder="••••••••" />

                            <button type="button"
                                    onclick="togglePassword('currentPass','icon1')"
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">

                                <span class="material-symbols-outlined"
                                      id="icon1">
                                    visibility
                                </span>

                            </button>

                        </div>

                        <span asp-validation-for="CurrentPassword"
                              class="text-red-500 text-xs">
                        </span>
                    </div>

                    <!-- NEW PASSWORD -->
                    <div>
                        <label class="text-sm font-bold">
                            كلمة المرور الجديدة
                        </label>

                        <div class="relative mt-2">

                            <input asp-for="NewPassword"
                                   id="newPass"
                                   type="password"
                                   class="w-full p-3 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-orange-300 pr-12"
                                   placeholder="••••••••" />

                            <button type="button"
                                    onclick="togglePassword('newPass','icon2')"
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">

                                <span class="material-symbols-outlined"
                                      id="icon2">
                                    visibility
                                </span>

                            </button>

                        </div>

                        <span asp-validation-for="NewPassword"
                              class="text-red-500 text-xs">
                        </span>
                    </div>

                    <!-- CONFIRM PASSWORD -->
                    <div>
                        <label class="text-sm font-bold">
                            تأكيد كلمة المرور الجديدة
                        </label>

                        <div class="relative mt-2">

                            <input asp-for="ConfirmPassword"
                                   id="confirmPass"
                                   type="password"
                                   class="w-full p-3 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-orange-300 pr-12"
                                   placeholder="••••••••" />

                            <button type="button"
                                    onclick="togglePassword('confirmPass','icon3')"
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">

                                <span class="material-symbols-outlined"
                                      id="icon3">
                                    visibility
                                </span>

                            </button>

                        </div>

                        <span asp-validation-for="ConfirmPassword"
                              class="text-red-500 text-xs">
                        </span>
                    </div>

                    <button type="submit"
                            class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold hover:opacity-90 transition">
                        حفظ التغييرات
                    </button>

                </form>

            </div>

        </div>

        <!-- RIGHT IMAGE -->
        <div class="hidden md:flex hero-bg items-center justify-center text-white p-10">

            <div>
                <h1 class="text-3xl font-black mb-4">
                    أوستاوي
                </h1>

                <p class="text-white/80">
                    حافظ على أمان حسابك باستخدام كلمة مرور قوية وتحديثها بشكل دوري.
                </p>
            </div>

        </div>

    </div>

    <script>
        function togglePassword(inputId, iconId) {

        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);

        const isPassword = input.type === "password";

        input.type = isPassword ? "text" : "password";

        icon.textContent = isPassword
        ? "visibility_off"
        : "visibility";
        }
    </script>

</body>
</html>