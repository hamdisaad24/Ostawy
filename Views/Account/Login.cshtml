@model Ostawy.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null; 
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>تسجيل الدخول - أوستاوي</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Noto Sans Arabic', sans-serif; background-color: #f8f9ff; margin: 0; padding: 0; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .hero-bg {
            background-image: linear-gradient(rgba(3,22,54,0.85), rgba(3,22,54,0.7)),
            url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800');
            background-size: cover; background-position: center;
        }
        .validation-summary-errors {
            background-color: #fef2f2; 
            border: 1px solid #fee2e2; 
            color: #b91c1c; 
            border-radius: 0.75rem;
            padding: 0.75rem; 
            margin-bottom: 1.5rem; 
            font-size: 0.875rem; 
            font-weight: 600; 
        }
        .validation-summary-errors ul {
            list-style-type: none;
            padding: 0; 
            margin: 0; 
        }


        
    /* إلغاء العين الافتراضية في متصفحات إيدج وكروم */
    input::-ms-reveal,
    input::-ms-clear {
        display: none !important;
    }
    
    input::-webkit-contacts-auto-fill-button,
    input::-webkit-credentials-auto-fill-button {
        display: none !important;
    }

    </style>
</head>
<body class="min-h-screen flex flex-col m-0 p-0">
    <div class="flex-grow grid grid-cols-1 md:grid-cols-2 m-0 p-0">

        <div class="hidden md:flex hero-bg relative p-12 flex-col justify-between text-white order-last md:order-first">
            <div class="z-10">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-white" style="font-variation-settings:'FILL' 1;">handyman</span>
                    </div>
                    <h1 class="text-3xl font-black">أوستاوي</h1>
                </a>
                <p class="text-white/85 text-lg max-w-md leading-relaxed">المنصة الرائدة لربطك بأفضل الفنيين والخبراء في منطقتك بكل سهولة وأمان.</p>
            </div>
            <div class="z-10 bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
                <div class="flex items-center gap-4 mb-2">
                    <span class="material-symbols-outlined text-orange-400" style="font-variation-settings:'FILL' 1;">verified</span>
                    <span class="font-bold">فنيون معتمدون ومضمونون</span>
                </div>
                <p class="text-white/80 text-sm">نضمن لك الجودة والاحترافية من خلال عملية فحص دقيقة لجميع مزودي الخدمة.</p>
            </div>
        </div>

        <div class="flex flex-col items-center justify-center p-4 md:p-12 bg-white m-0">
            <div class="w-full max-w-md m-0">
                <div class="md:hidden text-center mb-8 m-0">
                    <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center mx-auto mb-3 m-0">
                        <span class="material-symbols-outlined text-white text-3xl m-0" style="font-variation-settings:'FILL' 1;">handyman</span>
                    </div>
                    <h1 class="text-2xl font-black text-slate-900 m-0">أوستاوي</h1>
                </div>

                <div class="mb-8 m-0 p-0">
                    <h2 class="text-3xl font-black text-slate-900 mb-2 m-0 p-0">تسجيل الدخول</h2>
                    <p class="text-gray-500 m-0 p-0">مرحباً بك مجدداً، ابدأ رحلتك معنا الآن.</p>
                </div>

                <div asp-validation-summary="All"
                     class="text-red-600 text-sm mb-4 font-bold"></div>

                <div id="errorMsg" class="hidden mb-6 p-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm font-semibold m-0"></div>

                <form asp-controller="Account" asp-action="Login" method="post" id="loginForm" class="space-y-5 m-0 p-0">
                    <div class="m-0 p-0">
                        <label class="text-sm font-bold text-slate-900 block mb-1.5 m-0 p-0">البريد الإلكتروني أو رقم الهاتف</label>
                        <div class="relative m-0 p-0">
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-gray-400">mail</span>
                            <input asp-for="Email" id="emailInput" class="w-full pr-12 pl-4 py-3.5 rounded-xl border border-gray-200 focus:border-orange-400 focus:ring-2 focus:ring-orange-200 bg-gray-50 transition-all text-base outline-none m-0" placeholder="example@ostawy.com" type="text" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="m-0 p-0">
                        <label class="text-sm font-bold text-slate-900 block mb-1.5 m-0 p-0">كلمة المرور</label>
                        <div class="relative m-0 p-0">
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-gray-400">lock</span>
                            <input asp-for="Password" id="passInput" class="w-full pr-12 pl-12 py-3.5 rounded-xl border border-gray-200 focus:border-orange-400 focus:ring-2 focus:ring-orange-200 bg-gray-50 transition-all text-base outline-none m-0" placeholder="••••••••" type="password" />
                            <button onclick="togglePass()" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-orange-500" type="button">
                                <span class="material-symbols-outlined" id="passIcon">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="flex items-center justify-between m-0 p-0">
                        <label class="flex items-center gap-2 cursor-pointer group m-0 p-0">
                            <input asp-for="RememberMe" class="w-4 h-4 rounded border-gray-300 accent-orange-500" type="checkbox" />
                            <span class="text-sm text-gray-500 group-hover:text-orange-500 transition-colors">تذكرني</span>
                        </label>
                        <a class="text-sm text-orange-600 hover:underline font-semibold" asp-controller="Account" asp-action="ForgotPassword">نسيت كلمة المرور؟</a>
                    </div>

                    <button type="button" onclick="doLogin()" id="loginBtn" class="w-full py-4 bg-orange-500 text-white rounded-xl font-bold text-base shadow-lg hover:opacity-90 active:scale-[0.98] transition-all m-0">
                        تسجيل الدخول
                    </button>
                </form>

                <p class="mt-8 text-center text-gray-500 text-sm m-0">
                    ليس لديك حساب؟
                    <a class="text-orange-600 font-bold hover:underline mr-1" asp-controller="Account" asp-action="Register">سجل الآن مجاناً</a>
                </p>
            </div>
        </div>
    </div>

    <footer class="w-full py-4 border-t border-gray-100 bg-white m-0 p-0">
        <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-3 m-0">
            <p class="text-gray-400 text-sm m-0">© 2026 أوستاوي. جميع الحقوق محفوظة.</p>
            <div class="flex gap-6 m-0">
                <a class="text-gray-400 text-sm hover:text-orange-500" href="#">الشروط والأحكام</a>
                <a class="text-gray-400 text-sm hover:text-orange-500" href="#">سياسة الخصوصية</a>
                <a class="text-gray-400 text-sm hover:text-orange-500" href="#">تواصل معنا</a>
            </div>
        </div>
    </footer>

    <script>

        function togglePass() {
            const p = document.getElementById('passInput');
            const i = document.getElementById('passIcon');
            p.type = p.type === 'password' ? 'text' : 'password';
            i.textContent = p.type === 'password' ? 'visibility' : 'visibility_off';
        }

        function showError(msg) {
            const el = document.getElementById('errorMsg');
            el.textContent = msg;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 4000);
        }

        function doLogin() {
    const email = document.getElementById('emailInput').value.trim();
    const pass = document.getElementById('passInput').value;
    
    if (!email || !pass) {
        return showError('يرجى إدخال البيانات كاملة');
    }

    const btn = document.getElementById('loginBtn');
    btn.textContent = 'جاري التحقق...';
    btn.disabled = true;

    // 👈 التعديل السحري هنا: استخدام requestSubmit عشان يبعت الـ Tokens والـ Validation صح
    setTimeout(() => {
        const form = document.getElementById('loginForm');
        if (typeof form.requestSubmit === 'function') {
            form.requestSubmit();
        } else {
            form.submit();
        }
    }, 500);
}

        document.addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
    </script>
</body>
</html>