@model Ostawy.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>نسيت كلمة المرور - أوستاوي</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
        font-family: 'Noto Sans Arabic', sans-serif;
        background-color: #f8f9ff;
        margin: 0;
        padding: 0;
        }

        .hero-bg {
        background-image: linear-gradient(rgba(3,22,54,0.85), rgba(3,22,54,0.7)), url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800');
        background-size: cover;
        background-position: center;
        }

        .validation-summary-errors {
        background-color: #fef2f2;
        border: 1px solid #fee2e2;
        color: #b91c1c;
        border-radius: 0.75rem;
        padding: 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        }

        .validation-summary-errors ul {
        list-style: none;
        padding: 0;
        margin: 0;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col m-0 p-0">

    <div class="flex-grow grid grid-cols-1 md:grid-cols-2 m-0 p-0">

        <!-- LEFT IMAGE -->
        <div class="hidden md:flex hero-bg relative p-12 flex-col justify-between text-white order-last md:order-first">

            <div class="z-10">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center">
                        🔐
                    </div>
                    <h1 class="text-3xl font-black">أوستاوي</h1>
                </a>

                <p class="text-white/85 text-lg max-w-md leading-relaxed">
                    أدخل بريدك الإلكتروني وسنرسل لك رمز إعادة تعيين كلمة المرور.
                </p>
            </div>

            <div class="z-10 bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
                <p class="text-white/80 text-sm">
                    سيتم إرسال رمز التحقق إلى بريدك خلال ثواني.
                </p>
            </div>
        </div>

        <!-- RIGHT FORM -->
        <div class="flex flex-col items-center justify-center p-4 md:p-12 bg-white m-0">

            <div class="w-full max-w-md m-0">

                <h2 class="text-3xl font-black text-slate-900 mb-2">
                    نسيت كلمة المرور
                </h2>

                <p class="text-gray-500 mb-6">
                    أدخل البريد الإلكتروني لإرسال كود إعادة التعيين
                </p>

                <!-- VALIDATION -->
                <div asp-validation-summary="All"
                     class="text-red-600 text-sm mb-4 font-bold"></div>

                <form asp-action="ForgotPassword" method="post" class="space-y-5">

                    <div>
                        <label class="text-sm font-bold text-slate-900 block mb-1.5">
                            البريد الإلكتروني
                        </label>

                        <div class="relative">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400">
                                ✉️
                            </span>

                            <input asp-for="Email"
                                   class="w-full pr-12 pl-4 py-3.5 rounded-xl border border-gray-200
                            focus:border-orange-400 focus:ring-2 focus:ring-orange-200
                            bg-gray-50 outline-none"
                                   placeholder="example@domain.com" />
                        </div>

                        <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                    </div>

                    <button type="submit"
                            class="w-full py-4 bg-orange-500 text-white rounded-xl font-bold
                        hover:opacity-90 transition-all">
                        إرسال كود التحقق
                    </button>
                </form>

                <p class="mt-6 text-center text-sm text-gray-500">
                    رجوع إلى
                    <a asp-controller="Account" asp-action="Login"
                       class="text-orange-600 font-bold hover:underline">
                        تسجيل الدخول
                    </a>
                </p>

            </div>

        </div>

    </div>

</body>
</html>