@model Ostawy.Models.Category

<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-2xl shadow-xl border border-orange-200">
    <h2 class="text-2xl font-bold text-orange-900 mb-6 border-b pb-2">إضافة قسم جديد</h2>
    
    <form asp-action="Create" method="post">
        <div class="mb-4">
            <label class="block text-orange-800 font-bold mb-2">اسم القسم</label>
            <input asp-for="Name" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="مثلاً: نجارة" />
            <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-6">
            <label class="block text-orange-800 font-bold mb-2">كود الأيقونة (مثال: fa-solid fa-hammer)</label>
            <input asp-for="IconPath" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="fa-solid fa-hammer" />
        </div>

        <div class="flex justify-between items-center">
            <a asp-controller="Category" asp-action="Index" class="text-gray-500 hover:text-orange-600 font-bold">رجوع</a>
            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-full shadow-lg transition duration-300">
                حفظ القسم
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}