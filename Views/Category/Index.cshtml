@model IEnumerable<Ostawy.Models.Category>

<div class="max-w-5xl mx-auto mt-10 p-6 bg-white rounded-2xl shadow-xl border border-orange-200">
    <div class="flex justify-between items-center mb-6 border-b pb-4">
        <h2 class="text-3xl font-bold text-orange-900">قائمة الأقسام</h2>
        <a asp-controller="Category" asp-action="Create" 
           class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-full shadow-lg transition">
           إضافة قسم جديد
        </a>
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-100">
        <table class="min-w-full">
            <thead class="bg-orange-50">
                <tr class="text-orange-900">
                    <th class="py-4 px-6 text-right">اسم القسم</th>
                    <th class="py-4 px-6 text-center">الأيقونة</th>
                    <th class="py-4 px-6 text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var obj in Model)
                {
                    <tr class="hover:bg-orange-50 transition">
                        <td class="py-4 px-6 font-semibold text-gray-700">@obj.Name</td>
                        <td class="py-4 px-6 text-center text-orange-600 text-xl"><i class="@obj.IconPath"></i></td>
                        <td class="py-4 px-6 text-center">
                            <a asp-controller="Category" asp-action="Edit" asp-route-id="@obj.Id" 
                               class="text-orange-500 hover:text-orange-700 mx-2">
                               <i class="fas fa-edit"></i>
                            </a>
                            <a asp-controller="Category" asp-action="Delete" asp-route-id="@obj.Id" 
                               onclick="return confirm('هل انت متأكد من حذف هذا القسم؟')" 
                               class="text-red-500 hover:text-red-700 mx-2">
                               <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>