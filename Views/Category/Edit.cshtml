@model Ostawy.Models.Category

<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-2xl shadow-xl border border-orange-200">
    <h2 class="text-2xl font-bold text-orange-900 mb-6 border-b pb-2">تعديل القسم</h2>
    <form asp-action="Edit" method="post">
        <input asp-for="Id" hidden />
        
        <div class="mb-4">
            <label class="block text-orange-800 font-bold mb-2">اسم القسم</label>
            <input asp-for="Name" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:ring-2 focus:ring-orange-500" />
        </div>
        <div class="mb-6">
            <label class="block text-orange-800 font-bold mb-2">الأيقونة</label>
            <input asp-for="IconPath" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:ring-2 focus:ring-orange-500" />
        </div>
        
        <div class="flex justify-between items-center">
            <a asp-controller="Category" asp-action="Index" class="text-gray-500 font-bold">رجوع</a>
            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-full">حفظ التعديلات</button>
        </div>
    </form>
</div>